# Splunk credential file
# Copy this file to ./credentials (in the project root) and fill in your values:
#
#   cp credentials.example credentials
#   chmod 600 credentials
#   # Edit credentials with your actual values
#
# This file is read automatically by all skill scripts.
# The real credentials file is gitignored and will NOT be committed.

# --- Splunk REST API / SSH connection ---
# Host, management port, and optional SSH settings for remote installs.
# Values are literal strings; shell expressions are not executed.
# SPLUNK_URI defaults to https://localhost:8089 if not set.
SPLUNK_HOST="your-splunk-host"
SPLUNK_MGMT_PORT="8089"
SPLUNK_URI="https://your-splunk-host:8089"
SPLUNK_SSH_HOST="your-splunk-host"
SPLUNK_SSH_PORT="22"
SPLUNK_SSH_USER="splunk"
SPLUNK_SSH_PASS=""
SPLUNK_USER="admin"
SPLUNK_PASS="changeme"

# --- Splunkbase (splunk.com) credentials ---
# Required only when downloading TAs from Splunkbase.
# Use your splunk.com account email and password.
# Leave blank if you only install from local files or URLs.
SB_USER=""
SB_PASS=""
