# ShellCheck configuration for splunk-cloud-skills
# https://github.com/koalaman/shellcheck/wiki/Directive

# Allow sourcing files relative to the script location
source-path=SCRIPTDIR

# Shared library files are sourced, not executed directly
external-sources=true

# SC1091: not following sourced file — paths are resolved at runtime
disable=SC1091

# SC2034 (variable appears unused) is NOT globally disabled.
# Add per-line '# shellcheck disable=SC2034' annotations to specific
# variables that are intentionally set for callers in sourced libraries.
