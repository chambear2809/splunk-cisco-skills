# Splunk KV Store Administration Worksheet
#
# Non-secret values only. Do not store the Splunk admin password here.

deployment: standalone       # standalone | shc
phase: render                # render | status | backup | restore | migrate | resync

splunk_home: /opt/splunk
archive_name: kvstore_backup
restore_archive_name:        # leave blank to reuse archive_name on restore
storage_engine: unset        # unset | wiredTiger (set wiredTiger to plan a migration)

# Authenticate against splunkd interactively when running rendered scripts, or
# authenticate first with `splunk login`. Never place the password in argv or chat.
