{
  "version": 1,
  "description": "Source-specific readiness defaults and collection searches for the Splunk Data Source Readiness Doctor.",
  "packs": [
    {
      "id": "aws_cloudtrail",
      "label": "AWS CloudTrail",
      "docs": [
        "https://research.splunk.com/sources/e8ace6db-1dbd-4c72-a1fb-334684619a38/",
        "https://help.splunk.com/en/splunk-cloud-platform/get-data-in/splunk-supported-add-ons/amazon-kinesis-firehose"
      ],
      "match": {
        "app_names": ["Splunk_TA_aws", "splunk_app_aws"],
        "products": ["AWS CloudTrail", "Amazon Web Services"],
        "names": ["AWS CloudTrail"],
        "sourcetypes": ["aws:cloudtrail"]
      },
      "defaults": {
        "expected_sourcetypes": ["aws:cloudtrail"],
        "cim.expected_models": ["Authentication", "Change"],
        "cim.required_fields": ["user", "src", "eventName", "eventSource", "aws_account_id"],
        "es.expected_detection_families": ["aws_cloudtrail", "cloudtrail"],
        "ari.expected_processing_types": ["Cloud applications", "Identity"],
        "ari.processing_profile": {
          "processing_types": ["Cloud applications", "Identity"],
          "key_fields": ["user", "src", "eventName", "eventSource", "aws_account_id"],
          "relevant_event_filter": "eventName=* AND user=*"
        }
      },
      "handoffs": ["splunk-observability-aws-integration", "splunk-app-install", "splunk-enterprise-security-config"],
      "collection_searches": [
        {
          "id": "cloudtrail-actions",
          "title": "CloudTrail action, source, and account coverage",
          "category": "source-pack",
          "spl": "%BASE_SEARCH% earliest=-24h latest=now | stats count dc(user) as users dc(src) as srcs values(eventSource) as event_sources by eventName aws_account_id"
        },
        {
          "id": "cloudtrail-auth-change-candidates",
          "title": "CloudTrail authentication/change candidate fields",
          "category": "source-pack",
          "spl": "%BASE_SEARCH% earliest=-24h latest=now | eval action=coalesce(action,eventName) | stats count values(errorCode) as error_codes values(eventSource) as event_sources by user src action"
        }
      ]
    },
    {
      "id": "aws_security_lake_ocsf",
      "label": "Amazon Security Lake OCSF",
      "docs": [
        "https://research.splunk.com/sources/1dcf9cfb-0e91-44c6-81b3-61b2574ec898/",
        "https://help.splunk.com/en/splunk-cloud-platform/common-information-model/6.4/introduction/overview-of-the-ocsf-cim-add-on/configuring-ocsf-cim-add-on"
      ],
      "match": {
        "products": ["Amazon Security Lake", "AWS Security Lake"],
        "names": ["Amazon Security Lake", "ASL AWS CloudTrail"],
        "sourcetypes": ["aws:asl", "ocsf:aws:asl"],
        "sourcetype_prefixes": ["ocsf:aws:asl"]
      },
      "defaults": {
        "expected_sourcetypes": ["aws:asl", "ocsf:aws:asl"],
        "ocsf.required": true,
        "ocsf.expected_classes": ["API Activity", "Authentication", "Network Activity"],
        "cim.expected_models": ["Authentication", "Change", "Network_Traffic"],
        "cim.required_fields": ["class_name", "category_name", "activity_name", "time"],
        "ari.expected_processing_types": ["Cloud applications", "IP"],
        "ari.processing_profile": {
          "processing_types": ["Cloud applications", "IP"],
          "key_fields": ["class_name", "activity_name", "time"],
          "relevant_event_filter": "class_name=* AND activity_name=*"
        }
      },
      "handoffs": ["splunk-enterprise-security-config", "splunk-app-install", "splunk-federated-search-setup"],
      "collection_searches": [
        {
          "id": "ocsf-class-coverage",
          "title": "OCSF class/category/activity coverage",
          "category": "source-pack",
          "spl": "%BASE_SEARCH% earliest=-24h latest=now | stats count by class_name class_uid category_name category_uid activity_name activity_id sourcetype"
        },
        {
          "id": "ocsf-cim-bridge-candidates",
          "title": "OCSF-to-CIM bridge candidate fields",
          "category": "source-pack",
          "spl": "%BASE_SEARCH% earliest=-24h latest=now | head 500 | table _time sourcetype class_name activity_name src_endpoint.ip dst_endpoint.ip actor.user.name device.uid"
        }
      ]
    },
