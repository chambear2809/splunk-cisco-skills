# Cisco DC Networking account intake template
#
# Copy this file to `template.local` in the same folder before entering real
# values. Keep the completed file local only.
#
# Fill in non-secret values only. Do not store passwords or certificate material
# in `template.local`.
#
# Current first-party automation covers the core account fields below. Advanced
# certificate-path fields and detailed proxy settings are intentionally omitted
# because `configure_account.sh` does not prompt for them today.
#
# Create secret temp files only when you are ready to run the configure script:
# bash skills/shared/scripts/write_secret_file.sh /tmp/dc_aci_password
# bash skills/shared/scripts/write_secret_file.sh /tmp/dc_nd_password
# bash skills/shared/scripts/write_secret_file.sh /tmp/dc_nexus9k_password
#
# Then pass the matching file with `--password-file`.
#
# Fill in only the sections you plan to configure. Duplicate a section when you
# need more than one account of the same type.
#
# `stanza_name` is the account name that will appear in Splunk.

# Cisco ACI / APIC account
[aci_account]
stanza_name = ACI_PROD
hostname = apic1.example.local,apic2.example.local
port = 443
auth_type = password_authentication
login_domain =
username =
proxy_enabled = 0

# Cisco Nexus Dashboard account
[nexus_dashboard_account]
stanza_name = NEXUS_DASHBOARD_PROD
hostname = nd.example.local
port = 443
auth_type = password_authentication
login_domain =
username =
proxy_enabled = 0

# Cisco Nexus 9K account
[nexus_9k_account]
stanza_name = NEXUS9K_PROD
device_ip = 10.0.0.50
port = 443
username =
proxy_enabled = 0
