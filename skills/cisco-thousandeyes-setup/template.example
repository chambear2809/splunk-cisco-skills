# Cisco ThousandEyes account intake template
#
# Copy this file to `template.local` in the same folder before entering real values.
# Keep the completed file local only and never commit access tokens or refresh
# tokens to git.
#
# The ThousandEyes app uses OAuth 2.0 Device Code flow. The account stanza name is
# the ThousandEyes user email. Browser-based authorization is completed later by
# the account owner or delegated admin, so generated OAuth fields are intentionally
# omitted from this intake template.

[thousandeyes_account]
# Use the ThousandEyes user email as the stanza name.
stanza_name =

# Generated by the app during authorization and intentionally not requested here:
# access_token
# refresh_token
# device_code
# user_code
# verification_url
