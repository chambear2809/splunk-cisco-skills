# Cisco Meraki account intake template
#
# Copy this file to `template.local` in the same folder before entering real values.
# Keep the completed file local only and never commit API keys, OAuth client
# secrets, or tokens to git.
#
# Duplicate the section when you need more than one organization account.
#
# `stanza_name` is the account name that will appear in Splunk.
# Use either the basic API key path or the OAuth path for each account.
# Keep `base_url` aligned with `region`:
# - global: https://api.meraki.com
# - india: https://api.meraki.in
# - canada: https://api.meraki.ca
# - china: https://api.meraki.cn
# - fedramp: https://api.gov-meraki.com

[organization_account]
stanza_name =
organization_api_key =
organization_id =
region = global
base_url = https://api.meraki.com
max_api_calls_per_second = 5
auth_type = basic
automatic_input_creation = 1
automatic_input_creation_index = meraki
client_id =
client_secret =
domain =
endpoint = as.meraki.com
scope =
redirect_url =

# access_token and refresh_token are generated during the OAuth flow and are
# intentionally omitted from this intake template.
