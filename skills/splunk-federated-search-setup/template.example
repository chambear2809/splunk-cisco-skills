# Splunk Federated Search Setup Worksheet
#
# Multi-provider, multi-federated-index spec covering Federated Search
# for Splunk (FSS2S, type=splunk) and Amazon S3 federated dataset handoffs
# for Splunk Cloud Platform 10.4.2604+.
#
# Non-secret values only. Service-account passwords for FSS2S providers
# go in local-only password files referenced by `password_file`.
# Create them without shell-history exposure with:
#   bash skills/shared/scripts/write_secret_file.sh /tmp/federated_provider_password
#
# Splunk Cloud 10.4.2604+ admins create Amazon S3 connections and datasets in
# the Data Management app. Use fss3_mode: legacy only for older Cloud stacks or
# explicitly accepted migrations.

phase: render
apply_target: search-head            # search-head | shc-deployer | rest
cloud_version: 10.4.2604
fss3_mode: data-management           # data-management | legacy

splunk_home: /opt/splunk
app_name: ZZZ_cisco_skills_federated_search

# Global federated-search switch (POST /services/data/federated/settings/general).
# Leave true on the Federated Search Head for FSS to operate at all.
federated_search_enabled: true

# federated.conf [general] preview generation limits. 0 = Splunk default (unlimited).
max_preview_generation_duration: 0
max_preview_generation_inputcount: 0

# Search Head Cluster: required for replicating standard-mode federated index
# definitions across SHC members. Sets [shclustering] conf_replication_include.indexes = true
# in server.conf for the SHC deployer bundle.
shc_replication: true

# Restart Splunk after non-SHC apply. Ignored for shc-deployer (operator runs
# `splunk apply shcluster-bundle`) and for the rest target (REST writes
# typically take effect without a restart).
restart_splunk: true

# Splunk-to-Splunk providers (FSS2S, type=splunk).
# - Standard mode: requires app_context, requires federated indexes that
#   reference the provider, and supports many providers per remote host
#   (different app_context). useFSHKnowledgeObjects is forced to 0.
# - Transparent mode: ignores app_context, does NOT use federated indexes,
#   and does NOT support multiple providers pointing at the same remote
#   host. useFSHKnowledgeObjects is forced to 1.
# - Splunk Cloud→Splunk Enterprise federated search supports STANDARD MODE
#   ONLY. Transparent mode is not supported in that direction.
providers:
  - name: remote_prod
    type: splunk
    mode: standard
    host_port: remote-sh.example.com:8089
    service_account: federated_svc
    password_file: /tmp/federated_provider_password
    app_context: search
    disabled: false

  # Example second provider against the SAME remote host but a different app
  # context. Only valid in standard mode.
  # - name: remote_prod_es
  #   type: splunk
  #   mode: standard
  #   host_port: remote-sh.example.com:8089
  #   service_account: federated_svc
  #   password_file: /tmp/federated_provider_password
  #   app_context: SplunkEnterpriseSecuritySuite
  #   disabled: false

  # Example transparent-mode provider. Service account role on remote must
  # have list_search_head_clustering capability when the remote is an SHC
  # so Splunk can detect duplicate transparent providers across members.
  # - name: hybrid_migration
  #   type: splunk
  #   mode: transparent
  #   host_port: legacy-cloud.splunkcloud.com:8089
  #   service_account: hybrid_svc
  #   password_file: /tmp/hybrid_provider_password
  #   disabled: false

  # Amazon S3 federated dataset handoff. Splunk Cloud Platform 10.4.2604+ ONLY.
  # The renderer emits a Data Management handoff
  # (data-management-datasets/<name>.json). Set fss3_mode: legacy only when
  # you intentionally need the old FSS3 REST payload path.
  # - name: aws_logs
  #   type: aws_s3
  #   aws_account_id: "123456789012"   # 12-digit AWS account, quoted to keep YAML from coercing
  #   aws_region: us-west-2            # must match Splunk Cloud deployment region
  #   database: my_glue_db
  #   data_catalog: arn:aws:glue:us-west-2:123456789012:catalog
  #   aws_glue_tables_allowlist:
  #     - access_logs
  #     - app_logs
  #   aws_s3_paths_allowlist:
  #     - s3://my-bucket/access/
  #     - s3://my-bucket/app/
  #   aws_kms_keys_arn_allowlist:
  #     - arn:aws:kms:us-west-2:123456789012:key/abc-1234
  #   disabled: false

# Federated indexes (standard mode FSS2S, plus Amazon S3 dataset hints).
# Transparent mode providers do NOT use federated indexes; entries that
# reference a transparent-mode provider are rejected.
#
# dataset_type values:
# - FSS2S: index | metricindex | savedsearch | lastjob | datamodel
# - Amazon S3 Data Management handoff: glue_table (dataset_name is the Glue table name)
federated_indexes:
  - name: remote_main
    provider: remote_prod
    dataset_type: index
    dataset_name: main
    disabled: false

  # - name: remote_metrics
  #   provider: remote_prod
  #   dataset_type: metricindex
  #   dataset_name: cpu_metrics

  # - name: remote_es_notable
  #   provider: remote_prod_es
  #   dataset_type: savedsearch
  #   dataset_name: "Access - Authentication Failures - Rule"

  # - name: aws_access_logs
  #   provider: aws_logs
  #   dataset_type: glue_table
  #   dataset_name: access_logs
