<form version="1.1" theme="light" refresh="60">
  <label>Flow Overview</label>
  <fieldset submitButton="false" autoRun="false">
    <input type="time" token="time" searchWhenChanged="true">
      <label>Time</label>
      <default>
        <earliest>-60m@m</earliest>
        <latest>now</latest>
      </default>
    </input>
    <input type="dropdown" token="tk_fabricName" searchWhenChanged="true">
      <label>Fabric</label>
      <choice value="*">All</choice>
      <default>*</default>
      <fieldForLabel>fabricName</fieldForLabel>
      <fieldForValue>flows.fabricName</fieldForValue>
      <search>
        <query>|tstats `summariesonly` count from datamodel=Cisco_DCN_nexus_dashboard.flows by  flows.fabricName</query>
        <earliest>$time.earliest$</earliest>
        <latest>$time.latest$</latest>
      </search>
    </input>
  </fieldset>
  <row>
    <panel>
      <title>Total Flows</title>
      <single>
        <search>
          <query>| tstats `summariesonly` dc(flows.flowId) as Total_Flow from datamodel=Cisco_DCN_nexus_dashboard.flows WHERE flows.fabricName = "$tk_fabricName$" by _time</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
          <sampleRatio>1</sampleRatio>
        </search>
        <option name="colorBy">value</option>
        <option name="colorMode">block</option>
        <option name="drilldown">all</option>
        <option name="height">300</option>
        <option name="numberPrecision">0</option>
        <option name="rangeColors">["0x53a051","0x0877a6","0xf8be34","0xf1813f","0xdc4e41"]</option>
        <option name="rangeValues">[1000,2000,3000,4000]</option>
        <option name="refresh.display">progressbar</option>
        <option name="showSparkline">1</option>
        <option name="showTrendIndicator">1</option>
        <option name="trellis.enabled">0</option>
        <option name="trellis.scales.shared">1</option>
        <option name="trellis.size">large</option>
        <option name="trendColorInterpretation">standard</option>
        <option name="trendDisplayMode">absolute</option>
        <option name="underLabel">Flows</option>
        <option name="unitPosition">after</option>
        <option name="useColors">0</option>
        <option name="useThousandSeparators">1</option>
        <drilldown>
          <link target="_blank">search?q=%7C%20tstats%20%60summariesonly%60%20values(flows.dstIp)%20as%20dstIp%0D%0A%20%20%20%20%20%20%20%20%20values(flows.dstPort)%20as%20dstPort%0D%0A%20%20%20%20%20%20%20%20%20values(flows.fabricName)%20as%20fabricName%0D%0A%20%20%20%20%20%20%20%20%20values(flows.flowId)%20as%20flowId%0D%0A%20%20%20%20%20%20%20%20%20values(flows.ingressTenant)%20as%20ingressTenant%0D%0A%20%20%20%20%20%20%20%20%20values(flows.ingressVrf)%20as%20ingressVrf%0D%0A%20%20%20%20%20%20%20%20%20values(flows.srcEpg)%20as%20srcEpg%0D%0A%20%20%20%20%20%20%20%20%20values(flows.srcIp)%20as%20srcIp%0D%0A%20%20%20%20%20%20%20%20%20values(flows.srcPort)%20as%20srcPort%0D%0A%20%20%20%20%20%20%20%20%20values(flows.protocolName)%20as%20protocolName%0D%0A%20%20%20%20%20%20%20%20%20values(flows.nd_host)%20as%20nd_host%0D%0A%20%20%20%20%20%20%20%20%20values(flows.stats_dropReasons)%20as%20stats_dropReasons%0D%0A%20%20%20%20%20%20%20%20%20values(flows.stats_dropPktCount)%20as%20stats_dropPktCount%0D%0A%20%20%20%20%20%20%20%20%20values(flows.stats_nodeNames)%20as%20stats_nodeNames%0D%0A%20%20%20%20%20%20%20%20%20values(flows.stats_ingressByteCount)%20as%20stats_ingressByteCount%0D%0A%20%20%20%20%20%20%20%20%20values(flows.stats_egressByteCount)%20as%20stats_egressByteCount%0D%0A%20%20%20%20%20%20%20%20%20values(flows.stats_latency)%20as%20stats_latency%0D%0A%20%20%20%20%20%20%20%20%20values(flows.stats_ingressVif)%20as%20stats_ingressVif%0D%0A%20%20%20%20%20%20%20%20%20values(flows.stats_egressVif)%20as%20stats_egressVif%0D%0A%20%20%20%20%20%20%20%20%20from%20datamodel%3DCisco_DCN_nexus_dashboard.flows%0D%0A%20%20%20%20%20%20%20%20WHERE%20flows.fabricName%20%3D%20%22$tk_fabricName$%22%20by%20_time%2C%20flows.flowId%0D%0A%7C%20dedup%20flows.flowId%0D%0A%7C%20table%20_time%2C%20dstIp%2C%20dstPort%2C%20fabricName%2C%20flowId%2C%20ingressTenant%2C%20ingressVrf%2C%20srcEpg%2C%20srcIp%2C%20srcPort%2C%20protocolName%2C%20nd_host%2C%20stats_dropReasons%2C%20stats_dropPktCount%2C%20stats_nodeNames%2C%20stats_ingressByteCount%2C%20stats_egressByteCount%2C%20stats_latency%2C%20stats_ingressVif%2C%20stats_egressVif&amp;earliest=$time.earliest$&amp;latest=$time.latest$</link>
        </drilldown>
      </single>
    </panel>
    <panel>
      <title>Flows per Minute</title>
      <single>
        <search>
          <query>| tstats `summariesonly` dc(flows.flowId) as Count from datamodel=Cisco_DCN_nexus_dashboard.flows WHERE flows.fabricName = "$tk_fabricName$" by _time 
| eval Total_Flow=Round(Count/60,1) 
| fields - Count</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
          <sampleRatio>1</sampleRatio>
        </search>
        <option name="colorMode">block</option>
        <option name="drilldown">all</option>
        <option name="height">297</option>
        <option name="numberPrecision">0.0</option>
        <option name="rangeColors">["0x555","0x555"]</option>
        <option name="rangeValues">[0]</option>
        <option name="refresh.display">progressbar</option>
        <option name="trellis.enabled">0</option>
        <option name="trellis.scales.shared">1</option>
        <option name="trellis.size">large</option>
        <option name="underLabel">Flows / Minute</option>
        <option name="useColors">0</option>
        <drilldown>
          <link target="_blank">search?q=%7C%20tstats%20%60summariesonly%60%20dc(flows.flowId)%20as%20Count%20from%20datamodel%3DCisco_DCN_nexus_dashboard.flows%20WHERE%20flows.fabricName%20%3D%20%22$tk_fabricName$%22%20by%20_time%20%0A%7C%20eval%20Total_Flow%3DRound(Count%2F60%2C1)%20%0A%7C%20fields%20-%20Count&amp;earliest=$time.earliest$&amp;latest=$time.latest$</link>
        </drilldown>
      </single>
    </panel>
    <panel>
      <title>Flow Trend</title>
      <chart>
        <search>
          <query>| tstats `summariesonly` dc(flows.flowId) as Flow from datamodel=Cisco_DCN_nexus_dashboard.flows WHERE flows.fabricName = "$tk_fabricName$" by _time</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
          <sampleRatio>1</sampleRatio>
        </search>
        <option name="charting.axisLabelsX.majorLabelStyle.overflowMode">ellipsisNone</option>
        <option name="charting.axisLabelsX.majorLabelStyle.rotation">0</option>
        <option name="charting.axisTitleX.visibility">collapsed</option>
        <option name="charting.axisTitleY.text">Flows</option>
        <option name="charting.axisTitleY.visibility">visible</option>
        <option name="charting.axisTitleY2.visibility">visible</option>
        <option name="charting.axisX.abbreviation">none</option>
        <option name="charting.axisX.scale">linear</option>
        <option name="charting.axisY.abbreviation">none</option>
        <option name="charting.axisY.scale">linear</option>
        <option name="charting.axisY2.abbreviation">none</option>
        <option name="charting.axisY2.enabled">0</option>
        <option name="charting.axisY2.scale">inherit</option>
        <option name="charting.chart">area</option>
        <option name="charting.chart.bubbleMaximumSize">50</option>
        <option name="charting.chart.bubbleMinimumSize">10</option>
        <option name="charting.chart.bubbleSizeBy">area</option>
        <option name="charting.chart.nullValueMode">connect</option>
        <option name="charting.chart.showDataLabels">none</option>
        <option name="charting.chart.sliceCollapsingThreshold">0.01</option>
        <option name="charting.chart.stackMode">default</option>
        <option name="charting.chart.style">shiny</option>
        <option name="charting.drilldown">all</option>
        <option name="charting.layout.splitSeries">0</option>
        <option name="charting.layout.splitSeries.allowIndependentYRanges">0</option>
        <option name="charting.legend.labelStyle.overflowMode">ellipsisMiddle</option>
        <option name="charting.legend.mode">standard</option>
        <option name="charting.legend.placement">right</option>
        <option name="charting.lineWidth">2</option>
        <option name="height">300</option>
        <option name="refresh.display">progressbar</option>
        <option name="trellis.enabled">0</option>
        <option name="trellis.scales.shared">1</option>
        <option name="trellis.size">medium</option>
        <drilldown>
          <condition match="isnotnull('row._span') AND 'click.name2' != &quot;OTHER&quot;">
           <link target="_blank">search?q=%7C%20tstats%20%60summariesonly%60%20values(flows.dstIp)%20as%20dstIp%0D%0A%20%20%20%20%20%20%20%20%20values(flows.dstPort)%20as%20dstPort%0D%0A%20%20%20%20%20%20%20%20%20values(flows.srcIp)%20as%20srcIp%0D%0A%20%20%20%20%20%20%20%20%20values(flows.srcPort)%20as%20srcPort%0D%0A%20%20%20%20%20%20%20%20%20values(flows.protocolName)%20as%20protocolName%0D%0A%20%20%20%20%20%20%20%20%20values(flows.nd_host)%20as%20nd_host%0D%0A%20%20%20%20%20%20%20%20%20values(flows.stats_nodeNames)%20as%20stats_nodeNames%0D%0A%20%20%20%20%20%20%20%20%20values(flows.flowId)%20as%20flowId%0D%0A%20%20%20%20%20%20%20%20%20values(flows.fabricName)%20as%20fabricName%0D%0A%20%20%20%20%20%20%20%20%20values(flows.ingressTenant)%20as%20ingressTenant%0D%0A%20%20%20%20%20%20%20%20%20values(flows.ingressVrf)%20as%20ingressVrf%0D%0A%20%20%20%20%20%20%20%20%20values(flows.srcEpg)%20as%20srcEpg%0D%0A%20%20%20%20%20%20%20%20%20values(flows.stats_dropReasons)%20as%20stats_dropReasons%0D%0A%20%20%20%20%20%20%20%20%20values(flows.stats_dropPktCount)%20as%20stats_dropPktCount%0D%0A%20%20%20%20%20%20%20%20%20values(flows.stats_ingressByteCount)%20as%20stats_ingressByteCount%0D%0A%20%20%20%20%20%20%20%20%20values(flows.stats_egressByteCount)%20as%20stats_egressByteCount%0D%0A%20%20%20%20%20%20%20%20%20values(flows.stats_latency)%20as%20stats_latency%0D%0A%20%20%20%20%20%20%20%20%20values(flows.stats_ingressVif)%20as%20stats_ingressVif%0D%0A%20%20%20%20%20%20%20%20%20values(flows.stats_egressVif)%20as%20stats_egressVif%0D%0A%20%20%20%20%20%20%20%20%20from%20datamodel%3DCisco_DCN_nexus_dashboard.flows%0D%0A%20%20%20%20%20%20%20%20WHERE%20flows.fabricName%20%3D%20%22$tk_fabricName$%22%20by%20_time%2C%20flows.flowId%0D%0A%7C%20dedup%20flows.flowId%0D%0A%7C%20table%20_time%2C%20srcIp%2C%20srcPort%2C%20dstIp%2C%20dstPort%2C%20protocolName%2C%20nd_host%2C%20stats_nodeNames%2C%20flowId%2C%20fabricName%2C%20ingressTenant%2C%20ingressVrf%2C%20srcEpg%2C%20stats_dropReasons%2C%20stats_dropPktCount%2C%20stats_ingressByteCount%2C%20stats_egressByteCount%2C%20stats_latency%2C%20stats_ingressVif%2C%20stats_egressVif&amp;earliest=$earliest$&amp;latest=$latest$</link>
          </condition>
        </drilldown>
      </chart>
    </panel>
  </row>
  <row>
    <panel>
      <title>Flows</title>
      <table>
        <search>
          <query>| tstats `summariesonly` values(flows.protocolName) as "Protocol", values(flows.nd_host) as "Hostname" from datamodel=Cisco_DCN_nexus_dashboard.flows WHERE flows.fabricName = "$tk_fabricName$" by flows.srcIp, flows.srcPort, flows.dstIp, flows.dstPort, flows.stats_nodeNames, flows.flowId
| dedup flows.flowId
| eval Time=strftime(_time, "%Y-%m-%d %H:%M:%S.%3N"), stats_nodeNames=replace(trim(stats_nodeNames,"[']"),"', '"," &gt; ")
| table flows.stats_nodeNames, flows.srcIp, flows.srcPort, Hostname, Protocol, flows.dstIp, flows.dstPort
| rename flows.srcIp as "Source IP", flows.srcPort as "Source Port", flows.dstIp as "Destination IP", flows.dstPort as "Destination Port", flows.stats_nodeNames as "Node Names" 
| sort 0 - Time, Hostname</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
          <sampleRatio>1</sampleRatio>
        </search>
        <option name="count">6</option>
        <option name="dataOverlayMode">none</option>
        <option name="drilldown">row</option>
        <option name="percentagesRow">false</option>
        <option name="rowNumbers">false</option>
        <option name="totalsRow">false</option>
        <option name="wrap">false</option>
        <drilldown>
          <set token="row_hostname">$row.Hostname$</set>
          <set token="row_protocol">$row.Protocol$</set>
          <set token="row_destination_port">$row.Destination Port$</set>
          <set token="row_destination_ip">$row.Destination IP$</set>
          <set token="row_source_port">$row.Source Port$</set>
          <set token="row_source_ip">$row.Source IP$</set>
          <set token="row_node_names">$row.Node Names$</set>
          <link target="_blank">search?q=%7C%20tstats%20%60summariesonly%60%20values(flows.dstIp)%20as%20dstIp%0D%0A%20%20%20%20%20%20%20%20%20values(flows.dstPort)%20as%20dstPort%0D%0A%20%20%20%20%20%20%20%20%20values(flows.srcIp)%20as%20srcIp%0D%0A%20%20%20%20%20%20%20%20%20values(flows.srcPort)%20as%20srcPort%0D%0A%20%20%20%20%20%20%20%20%20values(flows.protocolName)%20as%20protocolName%0D%0A%20%20%20%20%20%20%20%20%20values(flows.nd_host)%20as%20nd_host%0D%0A%20%20%20%20%20%20%20%20%20values(flows.stats_nodeNames)%20as%20stats_nodeNames%0D%0A%20%20%20%20%20%20%20%20%20values(flows.flowId)%20as%20flowId%0D%0A%20%20%20%20%20%20%20%20%20values(flows.fabricName)%20as%20fabricName%0D%0A%20%20%20%20%20%20%20%20%20values(flows.ingressTenant)%20as%20ingressTenant%0D%0A%20%20%20%20%20%20%20%20%20values(flows.ingressVrf)%20as%20ingressVrf%0D%0A%20%20%20%20%20%20%20%20%20values(flows.srcEpg)%20as%20srcEpg%0D%0A%20%20%20%20%20%20%20%20%20values(flows.stats_dropReasons)%20as%20stats_dropReasons%0D%0A%20%20%20%20%20%20%20%20%20values(flows.stats_dropPktCount)%20as%20stats_dropPktCount%0D%0A%20%20%20%20%20%20%20%20%20values(flows.stats_ingressByteCount)%20as%20stats_ingressByteCount%0D%0A%20%20%20%20%20%20%20%20%20values(flows.stats_egressByteCount)%20as%20stats_egressByteCount%0D%0A%20%20%20%20%20%20%20%20%20values(flows.stats_latency)%20as%20stats_latency%0D%0A%20%20%20%20%20%20%20%20%20values(flows.stats_ingressVif)%20as%20stats_ingressVif%0D%0A%20%20%20%20%20%20%20%20%20values(flows.stats_egressVif)%20as%20stats_egressVif%0D%0A%20%20%20%20%20%20%20%20%20from%20datamodel%3DCisco_DCN_nexus_dashboard.flows%20WHERE%20flows.fabricName%20%3D%20%22$tk_fabricName$%22%20AND%20flows.stats_nodeNames%3D%22$row_node_names$%22%20AND%20flows.srcIp%3D%22$row_source_ip$%22%0D%0A%20%20%20%20%20%20%20%20%20%20%20AND%20flows.srcPort%3D%22$row_source_port$%22%0D%0A%20%20%20%20%20%20%20%20%20%20%20AND%20flows.dstIp%3D%22$row_destination_ip$%22%0D%0A%20%20%20%20%20%20%20%20%20%20%20AND%20flows.dstPort%3D%22$row_destination_port$%22%0D%0A%20%20%20%20%20%20%20%20%20%20%20AND%20flows.protocolName%3D%22$row_protocol$%22%0D%0A%20%20%20%20%20%20%20%20%20%20%20AND%20flows.nd_host%3D%22$row_hostname$%22%0D%0A%20%20%20%20%20%20%20%20%20by%20_time%2C%20flows.flowId%0D%0A%7C%20dedup%20flows.flowId%0D%0A%7C%20table%20_time%2C%20srcIp%2C%20srcPort%2C%20dstIp%2C%20dstPort%2C%20protocolName%2C%20nd_host%2C%20stats_nodeNames%2C%20flowId%2C%20fabricName%2C%20ingressTenant%2C%20ingressVrf%2C%20srcEpg%2C%20stats_dropReasons%2C%20stats_dropPktCount%2C%20stats_ingressByteCount%2C%20stats_egressByteCount%2C%20stats_latency%2C%20stats_ingressVif%2C%20stats_egressVif&amp;earliest=$time.earliest$&amp;latest=$time.latest$</link>
        </drilldown>
      </table>
    </panel>
  </row>
  <row>
    <panel>
      <title>Flow Drop Count</title>
      <single>
        <search>
          <query>| tstats `summariesonly` dc(flows.flowId) as "Drops" from datamodel=Cisco_DCN_nexus_dashboard.flows WHERE flows.stats_dropReasons!="0" flows.fabricName = "$tk_fabricName$" by flows.stats_dropReasons,_time
| fields - flows.stats_dropReasons</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
          <sampleRatio>1</sampleRatio>
        </search>
        <option name="colorBy">value</option>
        <option name="colorMode">block</option>
        <option name="drilldown">all</option>
        <option name="height">250</option>
        <option name="numberPrecision">0</option>
        <option name="rangeColors">["0x53a051","0x0877a6","0xf8be34","0xf1813f","0xdc4e41"]</option>
        <option name="rangeValues">[0,30,1000,2000]</option>
        <option name="refresh.display">progressbar</option>
        <option name="showSparkline">1</option>
        <option name="showTrendIndicator">1</option>
        <option name="trellis.enabled">0</option>
        <option name="trellis.scales.shared">1</option>
        <option name="trellis.size">large</option>
        <option name="trendColorInterpretation">standard</option>
        <option name="trendDisplayMode">absolute</option>
        <option name="underLabel">Drops</option>
        <option name="unitPosition">after</option>
        <option name="useColors">1</option>
