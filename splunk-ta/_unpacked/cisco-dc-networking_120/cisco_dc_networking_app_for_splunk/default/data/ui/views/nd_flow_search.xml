<form version="1.1" theme="light">
  <label>Flow Search</label>
  <fieldset submitButton="false" autoRun="false">
    <input type="time" token="time" searchWhenChanged="true">
      <label>Time</label>
      <default>
        <earliest>-60m@m</earliest>
        <latest>now</latest>
      </default>
    </input>
    <input type="dropdown" token="tk_fabricName" searchWhenChanged="true">
      <label>Fabric</label>
      <choice value="*">All</choice>
      <default>*</default>
      <fieldForLabel>fabricName</fieldForLabel>
      <fieldForValue>flows.fabricName</fieldForValue>
      <search>
        <query>|tstats `summariesonly` count from datamodel=Cisco_DCN_nexus_dashboard.flows by  flows.fabricName</query>
        <earliest>$time.earliest$</earliest>
        <latest>$time.latest$</latest>
      </search>
    </input>
    <input type="dropdown" token="tk_ingressTenant" searchWhenChanged="true">
      <label>Tenant</label>
      <choice value="*">All</choice>
      <default>*</default>
      <fieldForLabel>ingressTenant</fieldForLabel>
      <fieldForValue>flows.ingressTenant</fieldForValue>
      <search>
        <query>|tstats `summariesonly` count from datamodel=Cisco_DCN_nexus_dashboard.flows by  flows.fabricName, flows.ingressTenant
| search flows.fabricName=$tk_fabricName$</query>
        <earliest>$time.earliest$</earliest>
        <latest>$time.latest$</latest>
      </search>
    </input>
    <input type="dropdown" token="tk_ingressVrf" searchWhenChanged="true">
      <label>VRF</label>
      <choice value="*">All</choice>
      <default>*</default>
      <fieldForLabel>ingressVrf</fieldForLabel>
      <fieldForValue>flows.ingressVrf</fieldForValue>
      <search>
        <query>|tstats `summariesonly` count from datamodel=Cisco_DCN_nexus_dashboard.flows by  flows.fabricName, flows.ingressTenant, flows.ingressVrf
| search flows.fabricName=$tk_fabricName$ flows.ingressTenant=$tk_ingressTenant$</query>
        <earliest>$time.earliest$</earliest>
        <latest>$time.latest$</latest>
      </search>
    </input>
    <input type="text" token="tk_srcIp" searchWhenChanged="true">
      <label>Source IP</label>
      <default>*</default>
      <initialValue>*</initialValue>
    </input>
    <input type="text" token="tk_dstIp" searchWhenChanged="true">
      <label>Destination IP</label>
      <default>*</default>
      <initialValue>*</initialValue>
    </input>
    <input type="text" token="tk_dstPort" searchWhenChanged="true">
      <label>Destination Port</label>
      <default>*</default>
    </input>
  </fieldset>
  <row>
    <panel>
      <title>Flows</title>
      <table>
        <search>
          <query>| tstats `summariesonly` fillnull_value="N/A" count from datamodel=Cisco_DCN_nexus_dashboard.flows by _time, flows.fabricName, flows.srcIp, flows.dstIp, flows.stats_nodeNames, flows.srcPort, flows.dstPort, flows.stats_dropReasons, flows.ingressVrf, flows.srcEpg,  flows.stats_ingressVif, flows.stats_egressVif, flows.stats_latency, flows.stats_dropPktCount,  flows.ingressTenant
| search flows.fabricName=$tk_fabricName$ flows.ingressTenant=$tk_ingressTenant$ flows.ingressVrf=$tk_ingressVrf$ flows.srcIp=$tk_srcIp$ flows.dstIp=$tk_dstIp$ flows.dstPort=$tk_dstPort$
| eval Time=strftime(_time, "%Y-%m-%d %H:%M:%S.%3N"), stats_nodeNames=replace(trim(flows.stats_nodeNames,"[']"),"', '"," &gt; "), stats_ingressVif=trim(trim(flows.stats_ingressVif, "['"),"']"), stats_egressVif=trim(trim(flows.stats_egressVif, "['"),"']")
| table Time, flows.srcIp, flows.srcPort, flows.dstIp, flows.dstPort, flows.stats_latency, flows.stats_dropPktCount, flows.stats_dropReasons, flows.ingressTenant, flows.ingressVrf, flows.srcEpg, flows.stats_nodeNames, flows.stats_ingressVif, flows.stats_egressVif
| rename Time as "Time", flows.stats_nodeNames as "Switch", flows.stats_latency as "Latency (µs)", flows.stats_dropPktCount as "Drop Count", flows.stats_dropReasons as "Drop Reason", flows.srcIp as "Source IP", flows.srcPort as "Source Port", flows.dstIp as "Destination IP", flows.dstPort as "Destination Port", flows.ingressTenant as "Tenant", flows.ingressVrf as "VRF", flows.srcEpg as "EPG", flows.stats_ingressVif as "Ingress Interface", flows.stats_egressVif as "Egress Interface", flows.fabricName as "Fabric Name"</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
          <sampleRatio>1</sampleRatio>
        </search>
        <option name="count">100</option>
        <option name="dataOverlayMode">none</option>
        <option name="drilldown">row</option>
        <option name="percentagesRow">false</option>
        <option name="refresh.display">progressbar</option>
        <option name="rowNumbers">false</option>
        <option name="totalsRow">false</option>
        <option name="wrap">true</option>
        <drilldown>
          <set token="row_time">$row.Time$</set>
          <set token="row_srcip">$row.Source IP$</set>
          <set token="row_srcport">$row.Source Port$</set>
          <set token="row_dstip">$row.Destination IP$</set>
          <set token="row_dstport">$row.Destination Port$</set>
          <set token="row_statslatency">$row.Latency (µs)$</set>
          <set token="row_drppktcount">$row.Drop Count$</set>
          <set token="row_statsdrpreason">$row.Drop Reason$</set>
          <set token="row_ingresstenant">$row.Tenant$</set>
          <set token="row_ingressvrf">$row.VRF$</set>
          <set token="row_srcepg">$row.EPG$</set>
          <set token="row_statsnodenames">$row.Switch$</set>
          <set token="row_stats_ingressvif">$row.Ingress Interface$</set>
          <set token="row_statsegressvif">$row.Egress Interface$</set>
          <link target="_blank">search?q=%7C%20tstats%20%60summariesonly%60%20count%20from%20datamodel%3DCisco_DCN_nexus_dashboard.flows%20by%20_time%2C%20flows.fabricName%2C%20flows.srcIp%2C%20flows.dstIp%2C%20flows.stats_nodeNames%2C%20flows.srcPort%2C%20flows.dstPort%2C%20flows.stats_dropReasons%2C%20flows.ingressVrf%2C%20flows.srcEpg%2C%20%20flows.stats_ingressVif%2C%20flows.stats_egressVif%2C%20flows.stats_latency%2C%20flows.stats_dropPktCount%2C%20%20flows.ingressTenant%0D%0A%7C%20search%20flows.fabricName%3D$tk_fabricName$%20flows.ingressTenant%3D$tk_ingressTenant$%20flows.ingressVrf%3D$tk_ingressVrf$%20flows.srcIp%3D$tk_srcIp$%20flows.dstIp%3D$tk_dstIp$%20flows.dstPort%3D$tk_dstPort$%0D%0A%7C%20eval%20Time%3Dstrftime(_time%2C%20%22%25Y-%25m-%25d%20%25H%3A%25M%3A%25S.%253N%22)%2C%20stats_nodeNames%3Dreplace(trim(flows.stats_nodeNames%2C%22%5B'%5D%22)%2C%22'%2C%20'%22%2C%22%20%3E%20%22)%2C%20stats_ingressVif%3Dtrim(trim(flows.stats_ingressVif%2C%20%22%5B'%22)%2C%22'%5D%22)%2C%20stats_egressVif%3Dtrim(trim(flows.stats_egressVif%2C%20%22%5B'%22)%2C%22'%5D%22)%0D%0A|search%20Time%3D%22$row_time$%22%20AND%20flows.srcIp%20%3D%20%22$row_srcip$%22%20AND%20flows.srcPort%3D%22$row_srcport$%22%20AND%20flows.dstIp%3D%22$row_dstip$%22%20AND%20flows.dstPort%3D%22$row_dstport$%22%20AND%20flows.stats_latency%20%3D%20%22$row_statslatency$%22%20AND%20flows.stats_dropPktCount%3D%22$row_drppktcount$%22%20AND%20flows.stats_dropReasons%3D%22$row_statsdrpreason$%22%20AND%20flows.ingressTenant%3D%22$row_ingresstenant$%22%20AND%20flows.ingressVrf%3D%22$row_ingressvrf$%22%20AND%20flows.srcEpg%3D%22$row_srcepg$%22%20AND%20flows.stats_nodeNames%3D%22$row_statsnodenames$%22%20AND%20flows.stats_ingressVif%3D%22$row_stats_ingressvif$%22%20AND%20flows.stats_egressVif%3D%22$row_statsegressvif$%22%0D%0A%7C%20table%20Time%2C%20flows.srcIp%2C%20flows.srcPort%2C%20flows.dstIp%2C%20flows.dstPort%2C%20flows.stats_latency%2C%20flows.stats_dropPktCount%2C%20flows.stats_dropReasons%2C%20flows.ingressTenant%2C%20flows.ingressVrf%2C%20flows.srcEpg%2C%20flows.stats_nodeNames%2C%20flows.stats_ingressVif%2C%20flows.stats_egressVif%0D%0A%7C%20rename%20Time%20as%20%22Time%22%2C%20flows.stats_nodeNames%20as%20%22Switch%22%2C%20flows.stats_latency%20as%20%22Latency%20(%C2%B5s)%22%2C%20flows.stats_dropPktCount%20as%20%22Drop%20Count%22%2C%20flows.stats_dropReasons%20as%20%22Drop%20Reason%22%2C%20flows.srcIp%20as%20%22Source%20IP%22%2C%20flows.srcPort%20as%20%22Source%20Port%22%2C%20flows.dstIp%20as%20%22Destination%20IP%22%2C%20flows.dstPort%20as%20%22Destination%20Port%22%2C%20flows.ingressTenant%20as%20%22Tenant%22%2C%20flows.ingressVrf%20as%20%22VRF%22%2C%20flows.srcEpg%20as%20%22EPG%22%2C%20flows.stats_ingressVif%20as%20%22Ingress%20Interface%22%2C%20flows.stats_egressVif%20as%20%22Egress%20Interface%22%2C%20flows.fabricName%20as%20%22Fabric%20Name%22&amp;earliest=$time.earliest$&amp;latest=$time.latest$</link>
        </drilldown>
      </table>
    </panel>
  </row>
</form>