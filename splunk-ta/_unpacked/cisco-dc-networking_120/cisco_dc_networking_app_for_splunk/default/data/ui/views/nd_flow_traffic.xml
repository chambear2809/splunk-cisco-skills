<form version="1.1" theme="light" refresh="60">
  <label>Host Traffics</label>
  <fieldset submitButton="false">
    <input type="time" token="time" searchWhenChanged="true">
      <label>Time</label>
      <default>
        <earliest>-60m@m</earliest>
        <latest>now</latest>
      </default>
    </input>
    <input type="dropdown" token="tk_srcIp" searchWhenChanged="true">
      <label>Source IP</label>
      <choice value="*">All</choice>
      <default>*</default>
      <fieldForLabel>srcIp</fieldForLabel>
      <fieldForValue>flows.srcIp</fieldForValue>
      <search>
        <query>|tstats `summariesonly` count from datamodel=Cisco_DCN_nexus_dashboard.flows by  flows.flowId, flows.srcIp</query>
        <earliest>$time.earliest$</earliest>
        <latest>$time.latest$</latest>
      </search>
    </input>
  </fieldset>
  <row>
    <panel>
      <title>$tk_srcIp$ Host Traffic (KBPS)</title>
      <chart>
        <search>
          <query>| tstats `summariesonly` 
    sum(flows.stats_ingressByteCount) as ingress 
    sum(flows.stats_egressByteCount) as egress 
    from datamodel=Cisco_DCN_nexus_dashboard.flows 
    where flows.srcIp=$tk_srcIp$ 
    by _time, flows.srcIp
    span=1m
| eval req_KB=round(ingress/8/60, 1), res_KB=round(egress/8/60, 1)
| eval Bandwidth = req_KB + res_KB
| rename flows.srcIp as srcIp
| timechart sum(Bandwidth) as Bandwidth by srcIp</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
          <sampleRatio>1</sampleRatio>
        </search>
        <option name="charting.axisLabelsX.majorLabelStyle.overflowMode">ellipsisNone</option>
        <option name="charting.axisLabelsX.majorLabelStyle.rotation">0</option>
        <option name="charting.axisTitleX.visibility">collapsed</option>
        <option name="charting.axisTitleY.text">Byte/s</option>
        <option name="charting.axisTitleY.visibility">visible</option>
        <option name="charting.axisTitleY2.visibility">visible</option>
        <option name="charting.axisX.abbreviation">none</option>
        <option name="charting.axisX.scale">linear</option>
        <option name="charting.axisY.abbreviation">auto</option>
        <option name="charting.axisY.scale">linear</option>
        <option name="charting.axisY2.abbreviation">none</option>
        <option name="charting.axisY2.enabled">0</option>
        <option name="charting.axisY2.scale">inherit</option>
        <option name="charting.chart">area</option>
        <option name="charting.chart.bubbleMaximumSize">50</option>
        <option name="charting.chart.bubbleMinimumSize">10</option>
        <option name="charting.chart.bubbleSizeBy">area</option>
        <option name="charting.chart.nullValueMode">connect</option>
        <option name="charting.chart.showDataLabels">none</option>
        <option name="charting.chart.sliceCollapsingThreshold">0.01</option>
        <option name="charting.chart.stackMode">stacked</option>
        <option name="charting.chart.style">shiny</option>
        <option name="charting.drilldown">none</option>
        <option name="charting.layout.splitSeries">0</option>
        <option name="charting.layout.splitSeries.allowIndependentYRanges">0</option>
        <option name="charting.legend.labelStyle.overflowMode">ellipsisMiddle</option>
        <option name="charting.legend.mode">standard</option>
        <option name="charting.legend.placement">right</option>
        <option name="charting.lineWidth">2</option>
        <option name="refresh.display">progressbar</option>
        <option name="trellis.enabled">0</option>
        <option name="trellis.scales.shared">1</option>
        <option name="trellis.size">medium</option>
      </chart>
    </panel>
    <panel>
      <title>$tk_srcIp$ Host Traffic Count</title>
      <chart>
        <search>
          <query>| tstats `summariesonly` count from datamodel=Cisco_DCN_nexus_dashboard.flows by flows.srcIp, _time
| search flows.srcIp=$tk_srcIp$
| timechart count</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
          <sampleRatio>1</sampleRatio>
        </search>
        <option name="charting.axisTitleX.visibility">collapsed</option>
        <option name="charting.axisTitleY.text">Count</option>
        <option name="charting.axisY.abbreviation">none</option>
        <option name="charting.axisY.scale">linear</option>
        <option name="charting.chart">area</option>
        <option name="charting.chart.nullValueMode">connect</option>
        <option name="charting.drilldown">none</option>
        <option name="charting.legend.labelStyle.overflowMode">ellipsisEnd</option>
        <option name="charting.legend.placement">none</option>
        <option name="refresh.display">progressbar</option>
      </chart>
    </panel>
    <panel>
      <title>$tk_srcIp$ Drop Count</title>
      <chart>
        <search>
          <query>| tstats `summariesonly` count from datamodel=Cisco_DCN_nexus_dashboard.flows by flows.srcIp, flows.stats_dropPktCount, _time
| search flows.srcIp=$tk_srcIp$
| timechart sum(flows.stats_dropPktCount) by flows.srcIp</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
          <sampleRatio>1</sampleRatio>
        </search>
        <option name="charting.axisLabelsX.majorLabelStyle.overflowMode">ellipsisNone</option>
        <option name="charting.axisLabelsX.majorLabelStyle.rotation">0</option>
        <option name="charting.axisTitleX.text">Drops</option>
        <option name="charting.axisTitleX.visibility">collapsed</option>
        <option name="charting.axisTitleY.text">Drops</option>
        <option name="charting.axisTitleY.visibility">visible</option>
        <option name="charting.axisTitleY2.visibility">visible</option>
        <option name="charting.axisX.abbreviation">none</option>
        <option name="charting.axisX.scale">linear</option>
        <option name="charting.axisY.abbreviation">none</option>
        <option name="charting.axisY.scale">linear</option>
        <option name="charting.axisY2.abbreviation">none</option>
        <option name="charting.axisY2.enabled">0</option>
        <option name="charting.axisY2.scale">inherit</option>
        <option name="charting.chart">area</option>
        <option name="charting.chart.bubbleMaximumSize">50</option>
        <option name="charting.chart.bubbleMinimumSize">10</option>
        <option name="charting.chart.bubbleSizeBy">area</option>
        <option name="charting.chart.nullValueMode">connect</option>
        <option name="charting.chart.showDataLabels">none</option>
        <option name="charting.chart.sliceCollapsingThreshold">0.01</option>
        <option name="charting.chart.stackMode">stacked</option>
        <option name="charting.chart.style">shiny</option>
        <option name="charting.drilldown">none</option>
        <option name="charting.layout.splitSeries">0</option>
        <option name="charting.layout.splitSeries.allowIndependentYRanges">0</option>
        <option name="charting.legend.labelStyle.overflowMode">ellipsisMiddle</option>
        <option name="charting.legend.mode">standard</option>
        <option name="charting.legend.placement">none</option>
        <option name="charting.lineWidth">2</option>
        <option name="refresh.display">progressbar</option>
        <option name="trellis.enabled">0</option>
        <option name="trellis.scales.shared">1</option>
        <option name="trellis.size">medium</option>
      </chart>
    </panel>
  </row>
  <row>
    <panel>
      <title>$tk_srcIp$ Host(s)</title>
      <table>
        <search>
          <query>| tstats `summariesonly` fillnull_value="N/A" count from datamodel=Cisco_DCN_nexus_dashboard.flows by _time, flows.fabricName, flows.srcIp, flows.dstIp, flows.stats_nodeNames, flows.stats_ingressVif, flows.stats_egressVif, flows.srcPort, flows.dstPort, flows.stats_latency, flows.stats_dropPktCount, flows.stats_dropReasons, flows.ingressTenant, flows.ingressVrf, flows.srcEpg
| search flows.fabricName=* flows.ingressTenant=* flows.ingressVrf=* flows.srcIp=$tk_srcIp$ flows.dstIp=* flows.dstPort=*
| eval Time=strftime(_time, "%Y-%m-%d %H:%M:%S.%3N")
| table Time, flows.srcIp, flows.srcPort, flows.dstIp, flows.dstPort, flows.stats_latency, flows.stats_dropPktCount, flows.stats_dropReasons, flows.ingressTenant, flows.ingressVrf, flows.srcEpg, flows.stats_nodeNames, flows.stats_ingressVif, flows.stats_egressVif
| rename Time as "Time", flows.stats_nodeNames as "Switch", flows.stats_latency as "Latency (µs)", flows.stats_dropPktCount as "Drop Count", flows.stats_dropReasons as "Drop Reason", flows.srcIp as "Source IP", flows.srcPort as "Source Port", flows.dstIp as "Destination IP", flows.dstPort as "Destination Port", flows.ingressTenant as "Tenant", flows.ingressVrf as "VRF", flows.srcEpg as "EPG", flows.stats_ingressVif as "Ingress Interface", flows.stats_egressVif as "Egress Interface", flows.fabricName as "Fabric Name" | sort 0 - flows.Time</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
          <sampleRatio>1</sampleRatio>
        </search>
        <option name="count">20</option>
        <option name="dataOverlayMode">none</option>
        <option name="drilldown">row</option>
        <option name="percentagesRow">false</option>
        <option name="refresh.display">progressbar</option>
        <option name="rowNumbers">false</option>
        <option name="totalsRow">false</option>
        <option name="wrap">true</option>
        <drilldown>
          <set token="row_time">$row.Time$</set>
          <set token="row_srcip">$row.Source IP$</set>
          <set token="row_srcport">$row.Source Port$</set>
          <set token="row_dstip">$row.Destination IP$</set>
          <set token="row_dstport">$row.Destination Port$</set>
          <set token="row_statslatency">$row.Latency (µs)$</set>
          <set token="row_drppktcount">$row.Drop Count$</set>
          <set token="row_statsdrpreason">$row.Drop Reason$</set>
          <set token="row_ingresstenant">$row.Tenant$</set>
          <set token="row_ingressvrf">$row.VRF$</set>
          <set token="row_srcepg">$row.EPG$</set>
          <set token="row_statsnodenames">$row.Switch$</set>
          <set token="row_stats_ingressvif">$row.Ingress Interface$</set>
          <set token="row_statsegressvif">$row.Egress Interface$</set>
          <link target="_blank">search?q=%7C%20tstats%20%60summariesonly%60%20count%20from%20datamodel%3DCisco_DCN_nexus_dashboard.flows%20by%20_time%2C%20flows.fabricName%2C%20flows.srcIp%2C%20flows.dstIp%2C%20flows.stats_nodeNames%2C%20flows.stats_ingressVif%2C%20flows.stats_egressVif%2C%20flows.srcPort%2C%20flows.dstPort%2C%20flows.stats_latency%2C%20flows.stats_dropPktCount%2C%20flows.stats_dropReasons%2C%20flows.ingressTenant%2C%20flows.ingressVrf%2C%20flows.srcEpg%0A%7C%20search%20flows.fabricName%3D*%20flows.ingressTenant%3D*%20flows.ingressVrf%3D*%20flows.srcIp%3D$tk_srcIp$%20flows.dstIp%3D*%20flows.dstPort%3D*%0A%7C%20eval%20Time%3Dstrftime(_time%2C%20%22%25Y-%25m-%25d%20%25H%3A%25M%3A%25S.%253N%22)%0A|search%20Time%3D%22$row_time$%22%20AND%20flows.srcIp%20%3D%20%22$row_srcip$%22%20AND%20flows.srcPort%3D%22$row_srcport$%22%20AND%20flows.dstIp%3D%22$row_dstip$%22%20AND%20flows.dstPort%3D%22$row_dstport$%22%20AND%20flows.stats_latency%20%3D%20%22$row_statslatency$%22%20AND%20flows.stats_dropPktCount%3D%22$row_drppktcount$%22%20AND%20flows.stats_dropReasons%3D%22$row_statsdrpreason$%22%20AND%20flows.ingressTenant%3D%22$row_ingresstenant$%22%20AND%20flows.ingressVrf%3D%22$row_ingressvrf$%22%20AND%20flows.srcEpg%3D%22$row_srcepg$%22%20AND%20flows.stats_nodeNames%3D%22$row_statsnodenames$%22%20AND%20flows.stats_ingressVif%3D%22$row_stats_ingressvif$%22%20AND%20flows.stats_egressVif%3D%22$row_statsegressvif$%22%0A%7C%20table%20Time%2C%20flows.srcIp%2C%20flows.srcPort%2C%20flows.dstIp%2C%20flows.dstPort%2C%20flows.stats_latency%2C%20flows.stats_dropPktCount%2C%20flows.stats_dropReasons%2C%20flows.ingressTenant%2C%20flows.ingressVrf%2C%20flows.srcEpg%2C%20flows.stats_nodeNames%2C%20flows.stats_ingressVif%2C%20flows.stats_egressVif%0A%7C%20rename%20Time%20as%20%22Time%22%2C%20flows.stats_nodeNames%20as%20%22Switch%22%2C%20flows.stats_latency%20as%20%22Latency%20(%C2%B5s)%22%2C%20flows.stats_dropPktCount%20as%20%22Drop%20Count%22%2C%20flows.stats_dropReasons%20as%20%22Drop%20Reason%22%2C%20flows.srcIp%20as%20%22Source%20IP%22%2C%20flows.srcPort%20as%20%22Source%20Port%22%2C%20flows.dstIp%20as%20%22Destination%20IP%22%2C%20flows.dstPort%20as%20%22Destination%20Port%22%2C%20flows.ingressTenant%20as%20%22Tenant%22%2C%20flows.ingressVrf%20as%20%22VRF%22%2C%20flows.srcEpg%20as%20%22EPG%22%2C%20flows.stats_ingressVif%20as%20%22Ingress%20Interface%22%2C%20flows.stats_egressVif%20as%20%22Egress%20Interface%22%2C%20flows.fabricName%20as%20%22Fabric%20Name%22%20%7C%20sort%20-%20flows.Time&amp;earliest=$time.earliest$&amp;latest=$time.latest$</link>
        </drilldown>
      </table>
    </panel>
  </row>
</form>