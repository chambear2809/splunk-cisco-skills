<dashboard script="system_threshold.js" stylesheet="threshold_values.css" version="1.1">
  <label>Change EPG Threshold</label>
  <description>This dashboard allows user to modify EPG Threshold values</description>
  <row>
    <panel>
      <title>Current EPG Threshold Statistics</title>
      <table>
        <search id="search1">
          <query>| inputlookup cisco_dc_epgThreshold.csv 
                 | table warningThreshold, criticalThreshold, maxThreshold 
                 | rename warningThreshold as "Warning Threshold", criticalThreshold as "Critical Threshold", maxThreshold as "Max Threshold"</query>
          
        </search>
      </table>
    </panel>
  </row>
  <row>
    <panel>
      <html>
      <div class="flex">
        <div class="threshold_inputs">
          <label>Warning Threshold</label>
          <input class="input_style" type="text" id="warning_threshold"/>
        </div>
        <div class="threshold_inputs">
          <label>Critical Threshold</label>
          <input class="input_style" type="text" id="critical_threshold"/>
        </div>
        <div class="threshold_inputs">
          <label>Max Threshold</label>
          <input class="input_style" type="text" id="max_threshold"/>
        </div>
      </div>
      <div class="threshold_submit_button">
        <div class="submit_button">
          <input class="submitbutton" type="button" id="submit_button" value="Submit"/>
        </div>
        <div class="submit_button">
          <input class="cancel" type="button" id="cancel_button" value="Go back"/>
        </div>
      </div>
      <div class="threshold_submit_button" id="submit_button_status_msg">
      </div>
      </html>
    </panel>
  </row>
</dashboard>