<form version="1.1" script="multiselect.js" theme="light">
  <label>Endpoints</label>
  <fieldset submitButton="false">
    <input type="time" token="time">
      <label>Time</label>
      <default>
        <earliest>-60m@m</earliest>
        <latest>now</latest>
      </default>
    </input>
    <input type="multiselect" token="ip_tkn" searchWhenChanged="true">
      <label>IP</label>
      <default>*</default>
      <choice value="*">All</choice>
      <fieldForLabel>ip</fieldForLabel>
      <fieldForValue>ip</fieldForValue>
      <search>
        <query>| tstats `summariesonly` count from datamodel=Cisco_DCN_nexus_dashboard.endpoints by endpoints.ip
| rename endpoints.* as * 
| table ip
| dedup ip</query>
        <earliest>$time.earliest$</earliest>
        <latest>$time.latest$</latest>
      </search>
      <prefix>(</prefix>
      <suffix>)</suffix>
      <initialValue>*</initialValue>
      <valuePrefix>"</valuePrefix>
      <valueSuffix>"</valueSuffix>
      <delimiter> ,</delimiter>
    </input>
    <input type="multiselect" token="tenant_tkn">
      <label>Tenant</label>
      <default>*</default>
      <choice value="*">All</choice>
      <initialValue>*</initialValue>
      <fieldForLabel>tenant</fieldForLabel>
      <fieldForValue>tenant</fieldForValue>
      <search>
        <query>| tstats `summariesonly` count from datamodel=Cisco_DCN_nexus_dashboard.endpoints by endpoints.tenant
| rename endpoints.* as * 
| table tenant
| dedup tenant</query>
        <earliest>$time.earliest$</earliest>
        <latest>$time.latest$</latest>
      </search>
      <prefix>(</prefix>
      <suffix>)</suffix>
      <valuePrefix>"</valuePrefix>
      <valueSuffix>"</valueSuffix>
      <delimiter> ,</delimiter>
    </input>
    <input type="multiselect" token="bd_tkn">
      <label>BD</label>
      <fieldForLabel>displayBd</fieldForLabel>
      <fieldForValue>displayBd</fieldForValue>
      <search>
        <query>| tstats `summariesonly` count from datamodel=Cisco_DCN_nexus_dashboard.endpoints by endpoints.displayBd
| rename endpoints.* as * 
| table displayBd
| dedup displayBd</query>
        <earliest>$time.earliest$</earliest>
        <latest>$time.latest$</latest>
      </search>
      <prefix>(</prefix>
      <suffix>)</suffix>
      <valuePrefix>"</valuePrefix>
      <valueSuffix>"</valueSuffix>
      <delimiter> ,</delimiter>
      <choice value="*">All</choice>
      <default>*</default>
      <initialValue>*</initialValue>
    </input>
    <input type="multiselect" token="epg_tkn">
      <label>EPG/L3Out</label>
      <fieldForLabel>displayEpg</fieldForLabel>
      <fieldForValue>displayEpg</fieldForValue>
      <search>
        <query>| tstats `summariesonly` count from datamodel=Cisco_DCN_nexus_dashboard.endpoints by endpoints.displayEpg
| rename endpoints.* as * 
| table displayEpg
| dedup displayEpg</query>
        <earliest>$time.earliest$</earliest>
        <latest>$time.latest$</latest>
      </search>
      <prefix>(</prefix>
      <suffix>)</suffix>
      <valuePrefix>"</valuePrefix>
      <valueSuffix>"</valueSuffix>
      <delimiter> ,</delimiter>
      <choice value="*">All</choice>
      <default>*</default>
      <initialValue>*</initialValue>
    </input>
  </fieldset>
  <row>
    <panel>
      <title>Endpoint Count (Current)</title>
      <single>
        <search>
          <query>| tstats `summariesonly` dc(endpoints.endpointId) as "Count" from datamodel=Cisco_DCN_nexus_dashboard.endpoints where endpoints.ip IN $ip_tkn$ endpoints.tenant IN $tenant_tkn$ endpoints.displayBd IN $bd_tkn$ endpoints.displayEpg IN $epg_tkn$</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
          <sampleRatio>1</sampleRatio>
        </search>
        <option name="colorBy">value</option>
        <option name="colorMode">block</option>
        <option name="drilldown">all</option>
        <option name="height">251</option>
        <option name="numberPrecision">0</option>
        <option name="rangeColors">["0x555","0x555"]</option>
        <option name="rangeValues">[0]</option>
        <option name="refresh.display">progressbar</option>
        <option name="showSparkline">1</option>
        <option name="showTrendIndicator">1</option>
        <option name="trellis.enabled">0</option>
        <option name="trellis.scales.shared">1</option>
        <option name="trellis.size">large</option>
        <option name="trellis.splitBy">_aggregation</option>
        <option name="trendColorInterpretation">standard</option>
        <option name="trendDisplayMode">absolute</option>
        <option name="trendInterval">-1m</option>
        <option name="unitPosition">after</option>
        <option name="useColors">0</option>
        <option name="useThousandSeparators">1</option>
        <drilldown>
          <link target="_blank">search?q=%7C%20tstats%20%60summariesonly%60%0A%20%20%20%20values(endpoints.endpointId)%20as%20endpointId%0A%20%20%20%20values(endpoints.mac)%20as%20mac%0A%20%20%20%20values(endpoints.nodeName)%20as%20nodeName%0A%20%20%20%20values(endpoints.tenant)%20as%20tenant%0A%20%20%20%20values(endpoints.anomalyScore)%20as%20anomalyScore%0A%20%20%20%20values(endpoints.nd_host)%20as%20nd_host%0A%20%20%20%20values(endpoints.host)%20as%20host%0A%20%20%20%20values(endpoints.source)%20as%20source%0A%20%20%20%20values(endpoints.sourcetype)%20as%20sourcetype%0A%20%20%20%20values(endpoints.ip)%20as%20ip%0A%20%20%20%20values(endpoints.displayInterface)%20as%20displayInterface%0A%20%20%20%20from%20datamodel%3DCisco_DCN_nexus_dashboard.endpoints%20%0A%20%20%20%20where%20endpoints.ip%20IN%20$ip_tkn$%20endpoints.tenant%20IN%20$tenant_tkn$%20endpoints.displayBd%20IN%20$bd_tkn$%20endpoints.displayEpg%20IN%20$epg_tkn$%0A%20%20%20%20by%20_time%2C%20endpoints.endpointId%0A%7C%20dedup%20endpoints.endpointId%0A%7C%20eval%20Time%3Dstrftime(_time%2C%20%22%25Y-%25m-%25d%20%25H%3A%25M%3A%25S%22)%0A%7C%20table%20Time%2C%20endpointId%2C%20mac%2C%20nodeName%2C%20tenant%2C%20anomalyScore%2C%20nd_host%2C%20host%2C%20source%2C%20sourcetype%2C%20ip%2C%20displayInterface%0A%7C%20sort%20-%20Time&amp;earliest=$time.earliest$&amp;latest=$time.latest$</link>
        </drilldown>
      </single>
    </panel>
    <panel>
      <title>Endpoint Count Trend</title>
      <chart>
        <search>
          <query>| tstats `summariesonly` dc(endpoints.endpointId) as Endpoint from datamodel=Cisco_DCN_nexus_dashboard.endpoints   where endpoints.ip IN $ip_tkn$ endpoints.tenant IN $tenant_tkn$ endpoints.displayBd IN $bd_tkn$ endpoints.displayEpg IN $epg_tkn$ by _time</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
          <sampleRatio>1</sampleRatio>
        </search>
        <option name="charting.axisLabelsX.majorLabelStyle.overflowMode">ellipsisNone</option>
        <option name="charting.axisLabelsX.majorLabelStyle.rotation">0</option>
        <option name="charting.axisTitleX.visibility">collapsed</option>
        <option name="charting.axisTitleY.text">count</option>
        <option name="charting.axisTitleY.visibility">visible</option>
        <option name="charting.axisTitleY2.visibility">visible</option>
        <option name="charting.axisX.abbreviation">none</option>
        <option name="charting.axisX.scale">linear</option>
        <option name="charting.axisY.abbreviation">none</option>
        <option name="charting.axisY.scale">linear</option>
        <option name="charting.axisY2.abbreviation">none</option>
        <option name="charting.axisY2.enabled">0</option>
        <option name="charting.axisY2.scale">inherit</option>
        <option name="charting.chart">area</option>
        <option name="charting.chart.bubbleMaximumSize">50</option>
        <option name="charting.chart.bubbleMinimumSize">10</option>
        <option name="charting.chart.bubbleSizeBy">area</option>
        <option name="charting.chart.nullValueMode">connect</option>
        <option name="charting.chart.showDataLabels">none</option>
        <option name="charting.chart.sliceCollapsingThreshold">0.01</option>
        <option name="charting.chart.stackMode">default</option>
        <option name="charting.chart.style">shiny</option>
        <option name="charting.drilldown">all</option>
        <option name="charting.layout.splitSeries">1</option>
        <option name="charting.layout.splitSeries.allowIndependentYRanges">0</option>
        <option name="charting.legend.labelStyle.overflowMode">ellipsisMiddle</option>
        <option name="charting.legend.mode">standard</option>
        <option name="charting.legend.placement">right</option>
        <option name="charting.lineWidth">2</option>
        <option name="refresh.display">progressbar</option>
        <option name="trellis.enabled">0</option>
        <option name="trellis.scales.shared">1</option>
        <option name="trellis.size">medium</option>
        <drilldown>
          <condition match="isnotnull('row._span')">
            <link target="_blank">search?q=%60cisco_dc_nd_index%60%20sourcetype%3D%22cisco%3Adc%3And%3Aendpoints%22%20_time%20%3D%20$click.value$%20ip%7B%7D%20IN%20$ip_tkn$%20tenant%20IN%20$tenant_tkn$%20displayBd%20IN%20$bd_tkn$%20displayEpg%20IN%20$epg_tkn$&amp;earliest=$time.earliest$&amp;latest=$time.latest$</link>
          </condition>
        </drilldown>
      </chart>
    </panel>
    <panel>
      <title>Endpoint Health (Current)</title>
      <table>
        <search>
          <query>| tstats `summariesonly` avg(endpoints.anomalyScore) as "Anomaly Score"
        from datamodel=Cisco_DCN_nexus_dashboard.endpoints where endpoints.ip IN $ip_tkn$ endpoints.tenant IN $tenant_tkn$ endpoints.displayBd IN $bd_tkn$ endpoints.displayEpg IN $epg_tkn$ by endpoints.ip 
| rename endpoints.ip as "Endpoint IP"</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
          <sampleRatio>1</sampleRatio>
        </search>
        <option name="drilldown">none</option>
        <option name="refresh.display">progressbar</option>
      </table>
    </panel>
  </row>
  <row>
    <panel>
      <title>Endpoint Table (Current)</title>
      <table>
        <search>
          <query>| tstats `summariesonly` values(endpoints.anomalyScore) as anomalyScore, values(endpoints.tenant) as tenant values(endpoints.mac) as MAC values(endpoints.nodeName) as Switch values(endpoints.ip) as ip values(endpoints.displayInterface) as displayInterface values(endpoints.createTime) as "Created Time" values(endpoints.displayBd) as "BD" values(endpoints.displayEpg) as "EPG/L3Out" from datamodel=Cisco_DCN_nexus_dashboard.endpoints where endpoints.ip IN $ip_tkn$ AND endpoints.tenant IN $tenant_tkn$ endpoints.displayBd IN $bd_tkn$ endpoints.displayEpg IN $epg_tkn$ by _time, endpoints.endpointId
| dedup endpoints.endpointId
| eval healthy=case(anomalyScore&lt;=20,"Healthy", anomalyScore&gt;20 AND anomalyScore &lt;=60,"Warning", anomalyScore&gt;60 AND anomalyScore&lt;=80, "Major", anomalyScore&gt;80,"Critical")
| rename healthy as Health, tenant as Tenant, ip as IP, displayInterface as Interface
| table "Created Time", Health, Tenant, IP, MAC, Switch, Interface, "BD", "EPG/L3Out"
| sort 0 - Health, Hostname, IP</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
          <sampleRatio>1</sampleRatio>
        </search>
        <option name="count">20</option>
        <option name="dataOverlayMode">none</option>
        <option name="drilldown">row</option>
        <option name="percentagesRow">false</option>
        <option name="rowNumbers">true</option>
        <option name="totalsRow">false</option>
        <option name="wrap">true</option>
        <drilldown>
          <link target="_blank">search?q=%7C%20tstats%20%60summariesonly%60%0A%20%20%20%20values(endpoints.endpointId)%20as%20endpointId%0A%20%20%20%20values(endpoints.mac)%20as%20mac%0A%20%20%20%20values(endpoints.nodeName)%20as%20nodeName%0A%20%20%20%20values(endpoints.tenant)%20as%20tenant%0A%20%20%20%20values(endpoints.anomalyScore)%20as%20anomalyScore%0A%20%20%20%20values(endpoints.nd_host)%20as%20nd_host%0A%20%20%20%20values(endpoints.ip)%20as%20ip%0A%20%20%20%20values(endpoints.displayInterface)%20as%20displayInterface%0A%20%20%20%20from%20datamodel%3DCisco_DCN_nexus_dashboard.endpoints%20%0A%20%20%20%20where%20endpoints.ip%20IN%20$ip_tkn$%20endpoints.tenant%20IN%20$tenant_tkn$%20endpoints.displayBd%20IN%20$bd_tkn$%20endpoints.displayEpg%20IN%20$epg_tkn$%20AND%20endpoints.tenant%20%3D%20%22$row.Tenant$%22%20AND%20endpoints.mac%3D%22$row.MAC$%22%20AND%20endpoints.nodeName%20%3D%20%22$row.Switch$%22%20AND%20%20endpoints.displayInterface%3D%20%22$row.Interface$%22%20AND%20endpoints.displayBd%20%3D%20%22$row.BD$%22%0A%20%20%20%20by%20_time%2C%20endpoints.endpointId%0A%7C%20dedup%20endpoints.endpointId%0A%7C%20eval%20Time%3Dstrftime(_time%2C%20%22%25Y-%25m-%25d%20%25H%3A%25M%3A%25S%22)%0A%7C%20table%20Time%2C%20endpointId%2C%20mac%2C%20nodeName%2C%20tenant%2C%20anomalyScore%2C%20nd_host%2C%20ip%2C%20displayInterface%0A%7C%20sort%20-%20Time&amp;earliest=$time.earliest$&amp;latest=$time.latest$</link>
        </drilldown>
      </table>
    </panel>
  </row>
</form>