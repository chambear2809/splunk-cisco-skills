<form version="1.1" theme="light">
  <label>Orchestrator Syslog</label>
  <fieldset submitButton="false">
    <input type="time" token="time">
      <label>Time Range</label>
      <default>
        <earliest>-24h@h</earliest>
        <latest>now</latest>
      </default>
    </input>
    <input type="dropdown" token="table_size_tkn" searchWhenChanged="true">
      <label>No. of Recent Events</label>
      <choice value="10">Top 10</choice>
      <choice value="50">Top 50</choice>
      <choice value="100">Top 100</choice>
      <choice value="500">Top 500</choice>
      <default>100</default>
      <initialValue>100</initialValue>
    </input>
  </fieldset>
  <row>
    <panel>
      <title>Accounting Events by Severity</title>
      <chart>
        <search>
          <query>`cisco_dc_nd_index` sourcetype=cisco:dc:mso:syslog "*AAA_ACCOUNTING_MESSAGE*" 
| head $table_size_tkn$ 
| stats count by severity</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
        </search>
        <option name="charting.chart">pie</option>
        <option name="charting.drilldown">all</option>
        <option name="charting.fieldColors">{"critical":#D32F2F,"high":#F57C00,"medium":#FBC02D,"low":#388E3C,"informational":#1976D2}</option>
        <option name="refresh.display">progressbar</option>
        <drilldown>
          <link target="_blank">search?q=%60cisco_dc_nd_index%60%20sourcetype%3Dcisco%3Adc%3Amso%3Asyslog%20%22*AAA_ACCOUNTING_MESSAGE*%22%0A%7C%20head%20$table_size_tkn$%0A%7C%20search%20severity%3D$click.value$&amp;earliest=$time.earliest$&amp;latest=$time.latest$</link>
        </drilldown>
      </chart>
    </panel>
    <panel>
      <title>Accounting Events by Device IP/Name</title>
      <chart>
        <search>
          <query>`cisco_dc_nd_index` sourcetype=cisco:dc:mso:syslog "*AAA_ACCOUNTING_MESSAGE*"
| head $table_size_tkn$
| stats count by device_name_ip</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
        </search>
        <option name="charting.chart">pie</option>
        <option name="charting.drilldown">all</option>
        <option name="refresh.display">progressbar</option>
        <drilldown>
          <link target="_blank">search?q=%60cisco_dc_nd_index%60%20sourcetype%3Dcisco%3Adc%3Amso%3Asyslog%20%22*AAA_ACCOUNTING_MESSAGE*%22%0A%7C%20head%20$table_size_tkn$%0A%7C%20search%20device_name_ip%3D%22$click.value$%22&amp;earliest=$time.earliest$&amp;latest=$time.latest$</link>
        </drilldown>
      </chart>
    </panel>
