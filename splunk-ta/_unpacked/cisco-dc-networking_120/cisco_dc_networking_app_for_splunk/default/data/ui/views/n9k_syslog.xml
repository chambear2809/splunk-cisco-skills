<form version="1.1">
  <label>N9K Syslog</label>
  <fieldset autoRun="true" submitButton="false">
    <input type="time" searchWhenChanged="true" token="time">
      <label>Time Range</label>
      <default>
        <earliest>-24h@h</earliest>
        <latest>now</latest>
      </default>
    </input>
    <input type="dropdown" token="table_size_tkn" searchWhenChanged="true">
      <label>No. of Recent Events</label>
      <choice value="10">Top 10</choice>
      <choice value="50">Top 50</choice>
      <choice value="100">Top 100</choice>
      <choice value="500">Top 500</choice>
      <default>100</default>
      <initialValue>100</initialValue>
    </input>
  </fieldset>
  <row>
    <panel>
      <title>Configuration Events by Severity</title>
      <chart>
        <search>
          <query>`cisco_dc_n9k_index` sourcetype=cisco:dc:nexus9k:syslog *SYSLOG_CONFIG* 
| head $table_size_tkn$ 
| stats count by severity</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
        </search>
        <option name="charting.chart">pie</option>
        <option name="charting.drilldown">all</option>
        <option name="charting.fieldColors">{"critical":#D32F2F,"high":#F57C00,"medium":#FBC02D,"low":#388E3C,"informational":#1976D2}</option>
        <option name="refresh.display">progressbar</option>
        <drilldown>
          <link target="_blank">search?q=%60cisco_dc_n9k_index%60%20sourcetype%3Dcisco%3Adc%3Anexus9k%3Asyslog%20*SYSLOG_CONFIG*%20%0A%7C%20head%20$table_size_tkn$%20%0A%7C%20search%20severity%3D%22$click.value$%22&amp;earliest=$time.earliest$&amp;latest=$time.latest$</link>
        </drilldown>
      </chart>
    </panel>
    <panel>
      <title>Configuration Events by Device IP/Name</title>
      <chart>
        <search>
          <query>`cisco_dc_n9k_index` sourcetype=cisco:dc:nexus9k:syslog *SYSLOG_CONFIG* 
| head $table_size_tkn$ 
| stats count by device_name_ip
| rename device_name_ip as "Device IP/Name"</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
        </search>
        <option name="charting.chart">pie</option>
        <option name="charting.drilldown">all</option>
        <option name="refresh.display">progressbar</option>
        <drilldown>
          <link target="_blank">search?q=%60cisco_dc_n9k_index%60%20sourcetype%3Dcisco%3Adc%3Anexus9k%3Asyslog%20*SYSLOG_CONFIG*%20%0A%7C%20head%20$table_size_tkn$%20%0A%7C%20search%20device_name_ip%20%3D%20%22$click.value$%22&amp;earliest=$time.earliest$&amp;latest=$time.latest$</link>
        </drilldown>
      </chart>
    </panel>
    <panel>
      <title>Configuration Events by Target IP</title>
      <chart>
        <search>
          <query>`cisco_dc_n9k_index` sourcetype=cisco:dc:nexus9k:syslog *SYSLOG_CONFIG* 
| head $table_size_tkn$ 
| rex field=message "by (?&lt;user&gt;\w+) on (?&lt;ip&gt;[^\s@]+)" 
| stats count by ip</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
        </search>
        <option name="charting.chart">pie</option>
        <option name="charting.drilldown">all</option>
        <option name="refresh.display">progressbar</option>
        <drilldown>
          <link target="_blank">search?q=%60cisco_dc_n9k_index%60%20sourcetype%3Dcisco%3Adc%3Anexus9k%3Asyslog%20*SYSLOG_CONFIG*%20%0A%7C%20head%20$table_size_tkn$%20%0A%7C%20rex%20field%3Dmessage%20%22by%20(%3F%3Cuser%3E%5Cw%2B)%20on%20(%3F%3Cip%3E%5B%5E%5Cs%40%5D%2B)%22%20%0A%7C%20search%20ip%3D%22$click.value$%22&amp;earliest=$time.earliest$&amp;latest=$time.latest$</link>
        </drilldown>
      </chart>
    </panel>
