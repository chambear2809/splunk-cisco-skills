  <row>
    <panel>
      <title>Recent Configuration Events</title>
      <table>
        <search>
          <query>`cisco_dc_n9k_index` sourcetype=cisco:dc:nexus9k:syslog *SYSLOG_CONFIG* 
| head $table_size_tkn$ 
| rex field=message "by (?&lt;user&gt;\w+) on (?&lt;ip&gt;[^\s@]+)" 
| table event_time device_name_ip severity message ip vty_user 
| rename event_time as "Event Time" device_name_ip as "Device IP/Name" severity as Severity message as Message ip as "Target IP" vty_user as User</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
        </search>
        <option name="drilldown">none</option>
