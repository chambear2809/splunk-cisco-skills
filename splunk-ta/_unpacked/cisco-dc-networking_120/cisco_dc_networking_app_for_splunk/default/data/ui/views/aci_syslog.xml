<form version="1.1">
  <label>ACI Syslog</label>
  <fieldset submitButton="false" autoRun="true">
    <input type="time" searchWhenChanged="true" token="timetoken">
      <label>Time Range</label>
      <default>
        <earliest>-24h@h</earliest>
        <latest>now</latest>
      </default>
    </input>
    <input type="dropdown" token="table_size_tkn" searchWhenChanged="true">
      <label>No. of Recent Events</label>
      <choice value="10">Top 10</choice>
      <choice value="50">Top 50</choice>
      <choice value="100">Top 100</choice>
      <choice value="500">Top 500</choice>
      <default>100</default>
      <initialValue>100</initialValue>
    </input>
  </fieldset>
  <row>
    <panel>
      <title>Configuration Events by Device IP/Name</title>
      <chart>
        <search>
          <query>`cisco_dc_aci_index` sourcetype="cisco:dc:aci:syslog" "*SYSLOG_CONFIG*" 
| head $table_size_tkn$
| stats count by device_name_ip</query>
          <earliest>$timetoken.earliest$</earliest>
          <latest>$timetoken.latest$</latest>
        </search>
        <option name="charting.chart">pie</option>
        <option name="charting.drilldown">all</option>
        <option name="refresh.display">progressbar</option>
        <drilldown>
          <link target="_blank">search?q=%60cisco_dc_aci_index%60%20sourcetype%3D%22cisco%3Adc%3Aaci%3Asyslog%22%20%22*SYSLOG_CONFIG*%22%20%0A%7C%20head%20$table_size_tkn$%0A%7C%20search%20device_name_ip%3D%22$click.value$%22&amp;earliest=$timetoken.earliest$&amp;latest=$timetoken.latest$</link>
        </drilldown>
      </chart>
    </panel>
    <panel>
      <title>Configuration Events by Severity</title>
      <chart>
        <search>
          <query>`cisco_dc_aci_index` sourcetype="cisco:dc:aci:syslog" "*SYSLOG_CONFIG*" 
| head $table_size_tkn$
| stats count by severity</query>
          <earliest>$timetoken.earliest$</earliest>
          <latest>$timetoken.latest$</latest>
        </search>
        <option name="charting.chart">pie</option>
        <option name="charting.fieldColors">{"critical":#D32F2F,"high":#F57C00,"medium":#FBC02D,"low":#388E3C,"informational":#1976D2}</option>
        <option name="charting.drilldown">all</option>
        <option name="refresh.display">progressbar</option>
        <drilldown>
          <link target="_blank">search?q=%60cisco_dc_aci_index%60%20sourcetype%3D%22cisco%3Adc%3Aaci%3Asyslog%22%20%22*SYSLOG_CONFIG*%22%20%0A%7C%20head%20$table_size_tkn$%0A%7C%20search%20severity%3D%22$click.value$%22&amp;earliest=$timetoken.earliest$&amp;latest=$timetoken.latest$</link>
        </drilldown>
      </chart>
    </panel>
    <panel>
      <title>Configuration Events by User</title>
      <chart>
        <search>
          <query>`cisco_dc_aci_index` sourcetype="cisco:dc:aci:syslog" "*SYSLOG_CONFIG*" 
| head $table_size_tkn$
| rex field=message "by (?&lt;user&gt;\S+) on"
| stats count by user</query>
          <earliest>$timetoken.earliest$</earliest>
          <latest>$timetoken.latest$</latest>
        </search>
        <option name="charting.chart">pie</option>
        <option name="charting.drilldown">all</option>
        <option name="refresh.display">progressbar</option>
        <drilldown>
          <link target="_blank">search?q=%60cisco_dc_aci_index%60%20sourcetype%3D%22cisco%3Adc%3Aaci%3Asyslog%22%20%22*SYSLOG_CONFIG*%22%20%0A%7C%20head%20$table_size_tkn$%0A%7C%20rex%20field%3Dmessage%20%22by%20(%3F%3Cuser%3E%5CS%2B)%20on%22%0A%7C%20search%20user%3D%22$click.value$%22&amp;earliest=$timetoken.earliest$&amp;latest=$timetoken.latest$</link>
        </drilldown>
      </chart>
    </panel>
  </row>
  <row>
    <panel>
      <title>Recent Configuration Events</title>
      <table>
        <search>
          <query>`cisco_dc_aci_index` sourcetype="cisco:dc:aci:syslog" "*SYSLOG_CONFIG*" 
| head $table_size_tkn$
| rex field=message "by (?&lt;user&gt;\S+) on" 
| table event_time,device_name_ip,severity,message,user
| rename system_time as "System Time" event_time as "Event Time" device_name_ip as "Device IP/Name" facility as Facility severity as Severity message_code as "Message Code" message as Message user as User</query>
          <earliest>$timetoken.earliest$</earliest>
          <latest>$timetoken.latest$</latest>
        </search>
        <option name="count">10</option>
        <option name="dataOverlayMode">none</option>
        <option name="drilldown">none</option>
        <option name="percentagesRow">false</option>
        <option name="refresh.display">progressbar</option>
        <option name="rowNumbers">false</option>
        <option name="totalsRow">false</option>
        <option name="wrap">true</option>
      </table>
    </panel>
  </row>
  <row>
    <panel>
      <title>Missing Warning Events by Device IP/Name</title>
      <chart>
        <search>
          <query>`cisco_dc_aci_index` sourcetype="cisco:dc:aci:syslog" "*MISSING_WARNING*" 
| head $table_size_tkn$
| stats count by device_name_ip</query>
          <earliest>$timetoken.earliest$</earliest>
          <latest>$timetoken.latest$</latest>
        </search>
        <option name="charting.chart">pie</option>
        <option name="charting.drilldown">all</option>
        <option name="refresh.display">progressbar</option>
        <drilldown>
          <link target="_blank">search?q=%60cisco_dc_aci_index%60%20sourcetype%3D%22cisco%3Adc%3Aaci%3Asyslog%22%20%22*MISSING_WARNING*%22%20%0A%7C%20head%20$table_size_tkn$%0A%7C%20search%20device_name_ip%20%3D%20%22$click.value$%22&amp;earliest=$timetoken.earliest$&amp;latest=$timetoken.latest$</link>
        </drilldown>
      </chart>
    </panel>
    <panel>
      <title>Missing Warning Events by Severity</title>
      <chart>
        <search>
          <query>`cisco_dc_aci_index` sourcetype="cisco:dc:aci:syslog" "*MISSING_WARNING*" 
| head $table_size_tkn$
| stats count by severity</query>
          <earliest>$timetoken.earliest$</earliest>
          <latest>$timetoken.latest$</latest>
        </search>
        <option name="charting.chart">pie</option>
        <option name="charting.drilldown">all</option>
        <option name="charting.fieldColors">{"critical":#D32F2F,"high":#F57C00,"medium":#FBC02D,"low":#388E3C,"informational":#1976D2}</option>
        <option name="refresh.display">progressbar</option>
        <drilldown>
          <link target="_blank">search?q=%60cisco_dc_aci_index%60%20sourcetype%3D%22cisco%3Adc%3Aaci%3Asyslog%22%20%22*MISSING_WARNING*%22%20%0A%7C%20head%20$table_size_tkn$%0A%7C%20search%20severity%20%3D%20%22$click.value$%22&amp;earliest=$timetoken.earliest$&amp;latest=$timetoken.latest$</link>
        </drilldown>
      </chart>
    </panel>
  </row>
  <row>
    <panel>
      <title>Recent Missing Warning Events</title>
      <table>
        <search>
          <query>`cisco_dc_aci_index` sourcetype="cisco:dc:aci:syslog" "*MISSING_WARNING*" 
| head $table_size_tkn$
| table event_time,device_name_ip,severity,message
| rename system_time as "System Time" event_time as "Event Time" device_name_ip as "Device IP/Name" facility as Facility severity as Severity message_code as "Message Code" message as Message user as User</query>
          <earliest>$timetoken.earliest$</earliest>
          <latest>$timetoken.latest$</latest>
        </search>
        <option name="count">10</option>
        <option name="dataOverlayMode">none</option>
        <option name="drilldown">none</option>
        <option name="percentagesRow">false</option>
        <option name="refresh.display">progressbar</option>
        <option name="rowNumbers">false</option>
        <option name="totalsRow">false</option>
        <option name="wrap">true</option>
      </table>
    </panel>
  </row>
</form>