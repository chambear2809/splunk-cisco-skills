<form version="1.1" theme="light" refresh="60">
  <label>Interface Stats</label>
  <fieldset submitButton="false" autoRun="false">
    <input type="time" token="time" searchWhenChanged="true">
      <label>Time</label>
      <default>
        <earliest>-60m@m</earliest>
        <latest>now</latest>
      </default>
    </input>
    <input type="dropdown" token="interface_tkn" searchWhenChanged="true">
      <label>Interface Name</label>
      <selectFirstChoice>true</selectFirstChoice>
      <fieldForLabel>interfaceUniqueId</fieldForLabel>
      <fieldForValue>interfaceUniqueId</fieldForValue>
      <search>
        <query>| tstats `summariesonly` count from datamodel=Cisco_DCN_nexus_dashboard.protocols by protocols.interfaceUniqueId
| rename protocols.* as *</query>
        <earliest>$time.earliest$</earliest>
        <latest>$time.latest$</latest>
      </search>
      <choice value="*">All</choice>
      <default>*</default>
      <initialValue>*</initialValue>
    </input>
  </fieldset>
  <row>
    <panel>
      <title>Total Number of Interfaces</title>
      <single>
        <search>
          <query>| tstats `summariesonly` dc(protocols.interfaceUniqueId) from datamodel=Cisco_DCN_nexus_dashboard.protocols where protocols.interfaceUniqueId="$interface_tkn$" by _time</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
        </search>
        <option name="drilldown">all</option>
        <option name="refresh.display">progressbar</option>
        <drilldown>
          <link target="_blank">search?q=%7C%20tstats%20%60summariesonly%60%0A%20%20%20%20values(protocols.interfaceRateIngress)%20as%20interfaceRateIngress%0A%20%20%20%20values(protocols.fabricName)%20as%20fabricName%0A%20%20%20%20values(protocols.nodeName)%20as%20nodeName%0A%20%20%20%20values(protocols.siteName)%20as%20siteName%0A%20%20%20%20values(protocols.sourceName)%20as%20sourceName%0A%20%20%20%20values(protocols.sourceNameLabel)%20as%20sourceNameLabel%0A%20%20%20%20values(protocols.interfaceUniqueId)%20as%20interfaceUniqueId%0A%20%20%20%20values(protocols.adminStatus)%20as%20adminStatus%0A%20%20%20%20values(protocols.operStatus)%20as%20operStatus%0A%20%20%20%20values(protocols.interfaceType)%20as%20interfaceType%0A%20%20%20%20values(protocols.portSpeed)%20as%20portSpeed%0A%20%20%20%20values(protocols.anomalyScore)%20as%20anomalyScore%0A%20%20%20%20values(protocols.ipAddress)%20as%20ipAddress%0A%20%20%20%20values(protocols.ipv6Address)%20as%20ipv6Address%0A%20%20%20%20values(protocols.interfaceDescription)%20as%20interfaceDescription%0A%20%20%20%20values(protocols.l2NeighborString)%20as%20l2NeighborString%0A%20%20%20%20values(protocols.l2Neighbors)%20as%20l2Neighbors%0A%20%20%20%20values(protocols.logicalNeighborInfo)%20as%20logicalNeighborInfo%0A%20%20%20%20values(protocols.logicalNeighbors)%20as%20logicalNeighbors%0A%20%20%20%20from%20datamodel%3DCisco_DCN_nexus_dashboard.protocols%20where%20protocols.interfaceUniqueId%3D%22$interface_tkn$%22%0A%20%20%20%20by%20_time%2C%20protocols.interfaceUniqueId%0A%7C%20dedup%20protocols.interfaceUniqueId%0A%7C%20eval%20Time%3Dstrftime(_time%2C%20%22%25Y-%25m-%25d%20%25H%3A%25M%3A%25S%22)%0A%7C%20table%20Time%2C%20interfaceRateIngress%2C%20fabricName%2C%20nodeName%2C%20siteName%2C%20sourceName%2C%20sourceNameLabel%2C%20interfaceUniqueId%2C%20adminStatus%2C%20operStatus%2C%20interfaceType%2C%20portSpeed%2C%20anomalyScore%2C%20ipAddress%2C%20ipv6Address%2C%20interfaceDescription%2C%20l2NeighborString%2C%20l2Neighbors%2C%20logicalNeighborInfo%2C%20logicalNeighbors%0A%7C%20sort%20-%20Time&amp;earliest=$time.earliest$&amp;latest=$time.latest$</link>
        </drilldown>
      </single>
    </panel>
    <panel>
      <title>Number of Interfaces with Anomalies</title>
      <single>
        <search>
          <query>| tstats `summariesonly` dc(protocols.interfaceUniqueId) from datamodel=Cisco_DCN_nexus_dashboard.protocols where protocols.anomalyScore &gt; 0 protocols.interfaceUniqueId="$interface_tkn$"</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
        </search>
        <option name="drilldown">all</option>
        <option name="refresh.display">progressbar</option>
        <drilldown>
          <link target="_blank">search?q=%7C%20tstats%20%60summariesonly%60%0A%20%20%20%20values(protocols.interfaceRateIngress)%20as%20interfaceRateIngress%0A%20%20%20%20values(protocols.fabricName)%20as%20fabricName%0A%20%20%20%20values(protocols.nodeName)%20as%20nodeName%0A%20%20%20%20values(protocols.siteName)%20as%20siteName%0A%20%20%20%20values(protocols.sourceName)%20as%20sourceName%0A%20%20%20%20values(protocols.sourceNameLabel)%20as%20sourceNameLabel%0A%20%20%20%20values(protocols.interfaceUniqueId)%20as%20interfaceUniqueId%0A%20%20%20%20values(protocols.adminStatus)%20as%20adminStatus%0A%20%20%20%20values(protocols.operStatus)%20as%20operStatus%0A%20%20%20%20values(protocols.interfaceType)%20as%20interfaceType%0A%20%20%20%20values(protocols.portSpeed)%20as%20portSpeed%0A%20%20%20%20values(protocols.anomalyScore)%20as%20anomalyScore%0A%20%20%20%20values(protocols.ipAddress)%20as%20ipAddress%0A%20%20%20%20values(protocols.ipv6Address)%20as%20ipv6Address%0A%20%20%20%20values(protocols.interfaceDescription)%20as%20interfaceDescription%0A%20%20%20%20values(protocols.l2NeighborString)%20as%20l2NeighborString%0A%20%20%20%20values(protocols.l2Neighbors)%20as%20l2Neighbors%0A%20%20%20%20values(protocols.logicalNeighborInfo)%20as%20logicalNeighborInfo%0A%20%20%20%20values(protocols.logicalNeighbors)%20as%20logicalNeighbors%0A%20%20%20%20from%20datamodel%3DCisco_DCN_nexus_dashboard.protocols%0A%20%20%20%20where%20protocols.interfaceUniqueId%3D%22$interface_tkn$%22%20protocols.anomalyScore%20%3E%200%20%0A%20%20%20%20by%20_time%2C%20protocols.interfaceUniqueId%0A%7C%20dedup%20protocols.interfaceUniqueId%0A%7C%20eval%20Time%3Dstrftime(_time%2C%20%22%25Y-%25m-%25d%20%25H%3A%25M%3A%25S%22)%0A%7C%20table%20Time%2C%20interfaceRateIngress%2C%20fabricName%2C%20nodeName%2C%20siteName%2C%20sourceName%2C%20sourceNameLabel%2C%20interfaceUniqueId%2C%20adminStatus%2C%20operStatus%2C%20interfaceType%2C%20portSpeed%2C%20anomalyScore%2C%20ipAddress%2C%20ipv6Address%2C%20interfaceDescription%2C%20l2NeighborString%2C%20l2Neighbors%2C%20logicalNeighborInfo%2C%20logicalNeighbors%0A%7C%20sort%20-%20Time&amp;earliest=$time.earliest$&amp;latest=$time.latest$</link>
        </drilldown>
      </single>
    </panel>
  </row>
  <row>
    <panel>
      <title>Count of Interfaces by Operational Status</title>
      <chart>
        <search>
          <query>| tstats `summariesonly` latest(_time) as lastSeen latest(protocols.operStatus) as operStatus 
    from datamodel=Cisco_DCN_nexus_dashboard.protocols 
    where protocols.interfaceUniqueId="$interface_tkn$"
    by protocols.interfaceUniqueId 
| stats values(operStatus) as "Operational Status" by protocols.interfaceUniqueId
| mvexpand "Operational Status"
| stats count by "Operational Status"</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
        </search>
        <option name="charting.chart">bar</option>
        <option name="charting.drilldown">all</option>
        <option name="charting.legend.placement">none</option>
        <option name="refresh.display">progressbar</option>
        <drilldown>
          <link target="_blank">search?q=%7C%20tstats%20%60summariesonly%60%0A%20%20%20%20values(protocols.interfaceRateIngress)%20as%20interfaceRateIngress%0A%20%20%20%20values(protocols.fabricName)%20as%20fabricName%0A%20%20%20%20values(protocols.nodeName)%20as%20nodeName%0A%20%20%20%20values(protocols.siteName)%20as%20siteName%0A%20%20%20%20values(protocols.sourceName)%20as%20sourceName%0A%20%20%20%20values(protocols.sourceNameLabel)%20as%20sourceNameLabel%0A%20%20%20%20values(protocols.interfaceUniqueId)%20as%20interfaceUniqueId%0A%20%20%20%20values(protocols.adminStatus)%20as%20adminStatus%0A%20%20%20%20values(protocols.operStatus)%20as%20operStatus%0A%20%20%20%20values(protocols.interfaceType)%20as%20interfaceType%0A%20%20%20%20values(protocols.portSpeed)%20as%20portSpeed%0A%20%20%20%20values(protocols.anomalyScore)%20as%20anomalyScore%0A%20%20%20%20values(protocols.ipAddress)%20as%20ipAddress%0A%20%20%20%20values(protocols.ipv6Address)%20as%20ipv6Address%0A%20%20%20%20values(protocols.interfaceDescription)%20as%20interfaceDescription%0A%20%20%20%20values(protocols.l2NeighborString)%20as%20l2NeighborString%0A%20%20%20%20values(protocols.l2Neighbors)%20as%20l2Neighbors%0A%20%20%20%20values(protocols.logicalNeighborInfo)%20as%20logicalNeighborInfo%0A%20%20%20%20values(protocols.logicalNeighbors)%20as%20logicalNeighbors%0A%20%20%20%20from%20datamodel%3DCisco_DCN_nexus_dashboard.protocols%0A%20%20%20%20where%20protocols.interfaceUniqueId%3D%22$interface_tkn$%22%20protocols.operStatus%3D%22$click.value$%22%0A%20%20%20%20by%20_time%0A%7C%20eval%20Time%3Dstrftime(_time%2C%20%22%25Y-%25m-%25d%20%25H%3A%25M%3A%25S%22)%0A%7C%20table%20Time%2C%20interfaceRateIngress%2C%20fabricName%2C%20nodeName%2C%20siteName%2C%20sourceName%2C%20sourceNameLabel%2C%20interfaceUniqueId%2C%20adminStatus%2C%20operStatus%2C%20interfaceType%2C%20portSpeed%2C%20anomalyScore%2C%20ipAddress%2C%20ipv6Address%2C%20interfaceDescription%2C%20l2NeighborString%2C%20l2Neighbors%2C%20logicalNeighborInfo%2C%20logicalNeighbors%0A%7C%20sort%20-%20Time&amp;earliest=$time.earliest$&amp;latest=$time.latest$</link>
        </drilldown>
      </chart>
    </panel>
    <panel>
      <title>Distribution of Interface Types</title>
      <chart>
        <search>
          <query>| tstats `summariesonly` dc(protocols.interfaceUniqueId) as InterfaceCount 
        from datamodel=Cisco_DCN_nexus_dashboard.protocols 
        where protocols.interfaceUniqueId="$interface_tkn$"
        by protocols.interfaceType
| rename protocols.interfaceType as "Interface Type"</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
        </search>
        <option name="charting.chart">pie</option>
        <option name="charting.drilldown">all</option>
        <option name="refresh.display">progressbar</option>
        <drilldown>
          <link target="_blank">search?q=%7C%20tstats%20%60summariesonly%60%0A%20%20%20%20values(protocols.interfaceRateIngress)%20as%20interfaceRateIngress%0A%20%20%20%20values(protocols.fabricName)%20as%20fabricName%0A%20%20%20%20values(protocols.nodeName)%20as%20nodeName%0A%20%20%20%20values(protocols.siteName)%20as%20siteName%0A%20%20%20%20values(protocols.sourceName)%20as%20sourceName%0A%20%20%20%20values(protocols.sourceNameLabel)%20as%20sourceNameLabel%0A%20%20%20%20values(protocols.interfaceUniqueId)%20as%20interfaceUniqueId%0A%20%20%20%20values(protocols.adminStatus)%20as%20adminStatus%0A%20%20%20%20values(protocols.operStatus)%20as%20operStatus%0A%20%20%20%20values(protocols.interfaceType)%20as%20interfaceType%0A%20%20%20%20values(protocols.portSpeed)%20as%20portSpeed%0A%20%20%20%20values(protocols.anomalyScore)%20as%20anomalyScore%0A%20%20%20%20values(protocols.ipAddress)%20as%20ipAddress%0A%20%20%20%20values(protocols.ipv6Address)%20as%20ipv6Address%0A%20%20%20%20values(protocols.interfaceDescription)%20as%20interfaceDescription%0A%20%20%20%20values(protocols.l2NeighborString)%20as%20l2NeighborString%0A%20%20%20%20values(protocols.l2Neighbors)%20as%20l2Neighbors%0A%20%20%20%20values(protocols.logicalNeighborInfo)%20as%20logicalNeighborInfo%0A%20%20%20%20values(protocols.logicalNeighbors)%20as%20logicalNeighbors%0A%20%20%20%20from%20datamodel%3DCisco_DCN_nexus_dashboard.protocols%0A%20%20%20%20where%20protocols.interfaceUniqueId%3D%22$interface_tkn$%22%20protocols.interfaceType%3D%22$click.value$%22%0A%20%20%20%20by%20_time%2C%20protocols.interfaceUniqueId%0A%7C%20dedup%20protocols.interfaceUniqueId%0A%7C%20eval%20Time%3Dstrftime(_time%2C%20%22%25Y-%25m-%25d%20%25H%3A%25M%3A%25S%22)%0A%7C%20table%20Time%2C%20interfaceRateIngress%2C%20fabricName%2C%20nodeName%2C%20siteName%2C%20sourceName%2C%20sourceNameLabel%2C%20interfaceUniqueId%2C%20adminStatus%2C%20operStatus%2C%20interfaceType%2C%20portSpeed%2C%20anomalyScore%2C%20ipAddress%2C%20ipv6Address%2C%20interfaceDescription%2C%20l2NeighborString%2C%20l2Neighbors%2C%20logicalNeighborInfo%2C%20logicalNeighbors%0A%7C%20sort%20-%20Time&amp;earliest=$time.earliest$&amp;latest=$time.latest$</link>
        </drilldown>
      </chart>
    </panel>
  </row>
  <row>
    <panel>
      <title>Top 10 Anomalous Nodes</title>
      <chart>
        <search>
          <query>| tstats `summariesonly` avg(protocols.anomalyScore) as avgAnomalyScore 
    from datamodel=Cisco_DCN_nexus_dashboard.protocols
    where protocols.interfaceUniqueId="$interface_tkn$"
    by protocols.nodeName
| sort 0 -avgAnomalyScore
| head 10
| rename protocols.nodeName as "Node Name" avgAnomalyScore as "Anomaly Score"</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
        </search>
        <option name="charting.chart">bar</option>
        <option name="charting.drilldown">all</option>
        <option name="charting.legend.placement">none</option>
        <option name="refresh.display">progressbar</option>
        <drilldown>
          <link target="_blank">search?q=%7C%20tstats%20%60summariesonly%60%0A%20%20%20%20values(protocols.interfaceRateIngress)%20as%20interfaceRateIngress%0A%20%20%20%20values(protocols.fabricName)%20as%20fabricName%0A%20%20%20%20values(protocols.nodeName)%20as%20nodeName%0A%20%20%20%20values(protocols.siteName)%20as%20siteName%0A%20%20%20%20values(protocols.sourceName)%20as%20sourceName%0A%20%20%20%20values(protocols.sourceNameLabel)%20as%20sourceNameLabel%0A%20%20%20%20values(protocols.interfaceUniqueId)%20as%20interfaceUniqueId%0A%20%20%20%20values(protocols.adminStatus)%20as%20adminStatus%0A%20%20%20%20values(protocols.operStatus)%20as%20operStatus%0A%20%20%20%20values(protocols.interfaceType)%20as%20interfaceType%0A%20%20%20%20values(protocols.portSpeed)%20as%20portSpeed%0A%20%20%20%20values(protocols.anomalyScore)%20as%20anomalyScore%0A%20%20%20%20values(protocols.ipAddress)%20as%20ipAddress%0A%20%20%20%20values(protocols.ipv6Address)%20as%20ipv6Address%0A%20%20%20%20values(protocols.interfaceDescription)%20as%20interfaceDescription%0A%20%20%20%20values(protocols.l2NeighborString)%20as%20l2NeighborString%0A%20%20%20%20values(protocols.l2Neighbors)%20as%20l2Neighbors%0A%20%20%20%20values(protocols.logicalNeighborInfo)%20as%20logicalNeighborInfo%0A%20%20%20%20values(protocols.logicalNeighbors)%20as%20logicalNeighbors%0A%20%20%20%20from%20datamodel%3DCisco_DCN_nexus_dashboard.protocols%0A%20%20%20%20where%20protocols.interfaceUniqueId%3D%22$interface_tkn$%22%20protocols.nodeName%20%3D%20%22$click.value$%22%0A%20%20%20%20by%20_time%2C%20protocols.interfaceUniqueId%0A%7C%20dedup%20protocols.interfaceUniqueId%0A%7C%20search%20protocols.anomalyScore%3D%22$row.Total%20Anomaly%20Score$%22%0A%7C%20eval%20Time%3Dstrftime(_time%2C%20%22%25Y-%25m-%25d%20%25H%3A%25M%3A%25S%22)%0A%7C%20table%20Time%2C%20interfaceRateIngress%2C%20fabricName%2C%20nodeName%2C%20siteName%2C%20sourceName%2C%20sourceNameLabel%2C%20interfaceUniqueId%2C%20adminStatus%2C%20operStatus%2C%20interfaceType%2C%20portSpeed%2C%20anomalyScore%2C%20ipAddress%2C%20ipv6Address%2C%20interfaceDescription%2C%20l2NeighborString%2C%20l2Neighbors%2C%20logicalNeighborInfo%2C%20logicalNeighbors%0A%7C%20sort%20-%20Time&amp;earliest=$time.earliest$&amp;latest=$time.latest$</link>
        </drilldown>
      </chart>
    </panel>
    <panel>
      <title>Port Speed over Time per Interface (Gbps)</title>
      <chart>
        <search>
          <query>| tstats `summariesonly` latest(protocols.portSpeed) as portSpeed 
        from datamodel=Cisco_DCN_nexus_dashboard.protocols
        where protocols.interfaceUniqueId="$interface_tkn$"
        by _time, protocols.interfaceUniqueId 
        span=1h
| eval PortSpeed_Gbps = portSpeed / 1000000000
| timechart useother=0 span=1h latest(PortSpeed_Gbps) by protocols.interfaceUniqueId</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
        </search>
        <option name="charting.axisTitleX.text">Time</option>
        <option name="charting.chart">line</option>
        <option name="charting.chart.nullValueMode">connect</option>
        <option name="charting.drilldown">all</option>
        <option name="refresh.display">progressbar</option>
        <drilldown>
          <condition match="isnotnull('row._span')">
            <link target="_blank">search?q=%7C%20tstats%20%60summariesonly%60%20latest(protocols.portSpeed)%20as%20portSpeed%20%0D%0A%20%20%20%20%20%20%20%20from%20datamodel%3DCisco_DCN_nexus_dashboard.protocols%0D%0A%20%20%20%20%20%20%20%20where%20protocols.interfaceUniqueId%3D%22$interface_tkn$%22%0D%0A%20%20%20%20%20%20%20%20by%20_time%2C%20protocols.interfaceUniqueId%20%0D%0A%20%20%20%20%20%20%20%20span%3D1h%0D%0A%7C%20eval%20PortSpeed_Gbps%20%3D%20portSpeed%20%2F%201000000000%0D%0A%7C%20timechart%20useother%3D0%20span%3D1h%20latest(PortSpeed_Gbps)%20by%20protocols.interfaceUniqueId&amp;earliest=$time.earliest$&amp;latest=$time.latest$</link>
          </condition>
        </drilldown>
      </chart>
    </panel>
  </row>
  <row>
    <panel>
      <title>Interface Inventory Overview</title>
      <table>
        <search>
          <query>| tstats `summariesonly` 
    values(protocols.adminStatus) as adminStatus
    values(protocols.operStatus) as operStatus
    values(protocols.portSpeed) as portSpeed
    values(protocols.interfaceType) as interfaceType
    values(protocols.anomalyScore) as anomalyScore
    from datamodel=Cisco_DCN_nexus_dashboard.protocols
    where protocols.interfaceUniqueId="$interface_tkn$"
    by protocols.fabricName, protocols.nodeName, protocols.sourceNameLabel, protocols.interfaceUniqueId
| eval "Port Speed" = portSpeed / 1000000000
| rename 
    protocols.fabricName as "Fabric Name",
    protocols.nodeName as "Node Name",
    protocols.sourceNameLabel as "Source Name Label",
    protocols.interfaceUniqueId as "Interface Unique Id",
    adminStatus as "Admin Status",
    operStatus as "Operation Status",
    interfaceType as "Interface Type",
    anomalyScore as "Anomaly Score"
| table 
    "Fabric Name", "Node Name", "Source Name Label", "Interface Unique Id", 
    "Admin Status", "Operation Status", "Port Speed", "Interface Type", "Anomaly Score"</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
        </search>
        <option name="drilldown">row</option>
        <drilldown>
          <set token="row_fabric_name">$row.Fabric Name$</set>
          <set token="roe_node_name">$row.Node Name$</set>
          <set token="row_source_name_label">$row.Source Name Label$</set>
          <set token="row_interface_ui">$row.Interface Unique Id$</set>
          <set token="row_admin_status">$row.Admin Status$</set>
          <set token="row_oper_status">$row.Operation Status$</set>
          <set token="row_port_speed">$row.Port Speed$</set>
