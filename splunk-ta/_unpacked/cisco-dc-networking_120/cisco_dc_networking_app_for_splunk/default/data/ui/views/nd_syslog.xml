        </search>
        <option name="charting.chart">pie</option>
        <option name="charting.drilldown">all</option>
        <option name="refresh.display">progressbar</option>
        <drilldown>
          <link target="_blank">search?q=%60cisco_dc_nd_index%60%20sourcetype%3D%22cisco%3Adc%3And%3Asyslog%22%20%22*login%20from*%22%0A%7C%20head%20$table_size_tkn$%0A%7C%20search%20device_name_ip%3D%22$click.value$%22&amp;earliest=$time.earliest$&amp;latest=$time.latest$</link>
        </drilldown>
      </chart>
    </panel>
    <panel>
      <title>Login Attempts by User</title>
      <chart>
        <search>
          <query>`cisco_dc_nd_index` sourcetype="cisco:dc:nd:syslog" "*login from*"
| head $table_size_tkn$ 
| rex field=message "\"user\":\"(?&lt;user&gt;[^\"]+)\""
| stats count by user
| rename count as "Login Attempts"</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
        </search>
        <option name="charting.chart">pie</option>
        <option name="charting.drilldown">all</option>
        <option name="refresh.display">progressbar</option>
        <drilldown>
          <link target="_blank">search?q=%60cisco_dc_nd_index%60%20sourcetype%3D%22cisco%3Adc%3And%3Asyslog%22%20%22*login%20from*%22%0A%7C%20head%20$table_size_tkn$%0A%7C%20rex%20field%3Dmessage%20%22%5C%22user%5C%22%3A%5C%22(%3F%3Cuser%3E%5B%5E%5C%22%5D%2B)%5C%22%22%0A%7C%20search%20user%3D%22$click.value$%22&amp;earliest=$time.earliest$&amp;latest=$time.latest$</link>
        </drilldown>
      </chart>
    </panel>
    <panel>
      <title>Login Attempts from IP</title>
      <chart>
        <search>
          <query>`cisco_dc_nd_index` sourcetype="cisco:dc:nd:syslog" "*login from*"
| head $table_size_tkn$ 
| rex field=message "\"description\":\"(?&lt;login_description&gt;[^\"]+)\""
| rex field=login_description "login from (?&lt;login_from_ip&gt;\d{1,3}(?:\.\d{1,3}){3})"
| stats count by login_from_ip 
| rename count as "Login Attempts"</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
          <sampleRatio>1</sampleRatio>
        </search>
        <option name="charting.chart">pie</option>
        <option name="charting.drilldown">all</option>
        <option name="refresh.display">progressbar</option>
        <drilldown>
          <link target="_blank">search?q=%60cisco_dc_nd_index%60%20sourcetype%3D%22cisco%3Adc%3And%3Asyslog%22%20%22*login%20from*%22%0A%7C%20head%20$table_size_tkn$%0A%7C%20rex%20field%3Dmessage%20%22%5C%22description%5C%22%3A%5C%22(%3F%3Clogin_description%3E%5B%5E%5C%22%5D%2B)%5C%22%22%0A%7C%20rex%20field%3Dlogin_description%20%22login%20from%20(%3F%3Clogin_from_ip%3E%5Cd%7B1%2C3%7D(%3F%3A%5C.%5Cd%7B1%2C3%7D)%7B3%7D)%22%0A%7C%20search%20login_from_ip%3D%22$click.value$%22&amp;earliest=$time.earliest$&amp;latest=$time.latest$</link>
        </drilldown>
      </chart>
    </panel>
