| rex field=login_description "login from (?&lt;login_from_ip&gt;\d{1,3}(?:\.\d{1,3}){3})" 
| table event_time device_name_ip user login_description login_from_ip 
| rename event_time as "Event Time" device_name_ip as "Device IP/Name" user as "User" login_description as "Login Info" login_from_ip as "User Login IP"</query>
