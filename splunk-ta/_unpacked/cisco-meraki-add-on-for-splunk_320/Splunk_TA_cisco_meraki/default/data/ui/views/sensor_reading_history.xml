<form version="1.1">
  <label>Sensor Data</label>
  <fieldset submitButton="false">
    <input type="time" token="time">
      <label>Time</label>
      <default>
        <earliest>-24h@h</earliest>
        <latest>now</latest>
      </default>
    </input>
    <input type="dropdown" token="orgid">
      <label>Organization Id</label>
      <choice value="*">All</choice>
      <default>*</default>
      <prefix>organizationId = "</prefix>
      <suffix>"</suffix>
      <fieldForLabel>name</fieldForLabel>
      <fieldForValue>id</fieldForValue>
      <search>
        <query>`meraki_index` sourcetype="meraki:organizations"
| dedup id
| table id, name</query>
        <earliest>$time.earliest$</earliest>
        <latest>$time.latest$</latest>
      </search>
    </input>
  </fieldset>
  <row>
    <panel>
      <title>Average Temperature</title>
      <chart>
        <search>
          <query>`meraki_index` sourcetype="meraki:sensorreadingshistory" $orgid$ metric="temperature" 
| eval _time=coalesce(_time, strptime(ts, "%Y-%m-%dT%H:%M:%S.%6NZ")) 
| timechart avg(temperature.celsius) as "Temperature (°C)" span=1h</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
        </search>
        <option name="charting.axisTitleX.text">Time</option>
        <option name="charting.axisTitleX.visibility">visible</option>
        <option name="charting.axisTitleY.visibility">visible</option>
        <option name="charting.axisTitleY2.visibility">visible</option>
        <option name="charting.axisY2.enabled">0</option>
        <option name="charting.chart">line</option>
        <option name="charting.chart.nullValueMode">connect</option>
        <option name="charting.chart.showDataLabels">none</option>
        <option name="charting.drilldown">none</option>
        <option name="charting.layout.splitSeries">0</option>
        <option name="charting.legend.placement">right</option>
        <option name="refresh.display">progressbar</option>
        <option name="trellis.enabled">0</option>
        <option name="trellis.scales.shared">0</option>
        <option name="trellis.size">large</option>
      </chart>
    </panel>
  </row>
  <row>
    <panel>
      <title>Average Noise Level</title>
      <chart>
        <search>
          <query>`meraki_index` sourcetype="meraki:sensorreadingshistory" $orgid$ metric="noise"
| timechart avg(noise.ambient.level) as "Noise Level" span=1h</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
        </search>
        <option name="charting.axisTitleX.text">Time</option>
        <option name="charting.chart">line</option>
        <option name="charting.chart.nullValueMode">connect</option>
        <option name="charting.chart.showDataLabels">none</option>
        <option name="charting.drilldown">none</option>
        <option name="refresh.display">progressbar</option>
      </chart>
    </panel>
  </row>
  <row>
    <panel>
      <title>Average Indoor Air Quality Index</title>
      <chart>
        <search>
          <query>`meraki_index` sourcetype="meraki:sensorreadingshistory" $orgid$ metric="indoorAirQuality" 
| timechart avg(indoorAirQuality.score) AS "Indoor Air Quality Score" span=1h</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
        </search>
        <option name="charting.axisTitleX.text">Time</option>
        <option name="charting.chart">line</option>
        <option name="charting.chart.nullValueMode">connect</option>
        <option name="charting.chart.showDataLabels">none</option>
        <option name="charting.drilldown">none</option>
        <option name="refresh.display">progressbar</option>
      </chart>
    </panel>
  </row>
  <row>
    <panel>
      <title>Average PM2.5 Concentration</title>
      <chart>
        <search>
          <query>`meraki_index` sourcetype="meraki:sensorreadingshistory" $orgid$ metric="pm25" 
| timechart avg(pm25.concentration) as "Concentration" span=1h</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
        </search>
        <option name="charting.axisTitleX.text">Time</option>
        <option name="charting.chart">line</option>
        <option name="charting.chart.nullValueMode">connect</option>
        <option name="charting.chart.showDataLabels">none</option>
        <option name="charting.drilldown">none</option>
        <option name="refresh.display">progressbar</option>
      </chart>
    </panel>
  </row>
  <row>
    <panel>
      <title>Average CO2 Concentration</title>
      <chart>
        <search>
          <query>`meraki_index` sourcetype="meraki:sensorreadingshistory" $orgid$ metric="co2" 
| timechart avg(co2.concentration) as "Concentration" span=1h</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
        </search>
        <option name="charting.axisTitleX.text">Time</option>
        <option name="charting.chart">line</option>
        <option name="charting.chart.nullValueMode">connect</option>
        <option name="charting.chart.showDataLabels">none</option>
        <option name="charting.drilldown">none</option>
        <option name="refresh.display">progressbar</option>
      </chart>
    </panel>
  </row>
  <row>
    <panel>
      <title>Average TVOC Concentration</title>
      <chart>
        <search>
          <query>`meraki_index` sourcetype="meraki:sensorreadingshistory" $orgid$ metric="tvoc" 
| timechart avg(tvoc.concentration) as "Concentration" span=5m</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
        </search>
        <option name="charting.axisTitleX.text">Time</option>
        <option name="charting.chart">line</option>
        <option name="charting.chart.nullValueMode">connect</option>
        <option name="charting.chart.showDataLabels">none</option>
        <option name="charting.drilldown">none</option>
        <option name="refresh.display">progressbar</option>
      </chart>
    </panel>
  </row>
  <row>
    <panel>
      <title>Average Relative Humidity</title>
      <chart>
        <search>
          <query>`meraki_index` sourcetype="meraki:sensorreadingshistory" $orgid$ metric="humidity" 
| timechart avg(humidity.relativePercentage) as "Relative Percentage" span=1h</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
        </search>
        <option name="charting.axisTitleX.text">Time</option>
        <option name="charting.chart">line</option>
        <option name="charting.chart.nullValueMode">connect</option>
        <option name="charting.drilldown">none</option>
        <option name="refresh.display">progressbar</option>
      </chart>
    </panel>
  </row>
</form>