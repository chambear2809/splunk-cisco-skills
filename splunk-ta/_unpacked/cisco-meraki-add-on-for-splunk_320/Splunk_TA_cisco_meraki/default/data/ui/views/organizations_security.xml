<form version="1.1">
  <label>Organizations Security</label>
  <fieldset submitButton="false">
    <input type="time" token="time">
      <label>Time</label>
      <default>
        <earliest>-24h@h</earliest>
        <latest>now</latest>
      </default>
    </input>
    <input type="dropdown" token="orgid">
      <label>Organization Id</label>
      <choice value="*">All</choice>
      <default>*</default>
      <prefix>organizationId = "</prefix>
      <suffix>"</suffix>
      <fieldForLabel>name</fieldForLabel>
      <fieldForValue>id</fieldForValue>
      <search>
        <query>`meraki_index` sourcetype="meraki:organizations"
| dedup id
| table id, name</query>
        <earliest>$time.earliest$</earliest>
        <latest>$time.latest$</latest>
      </search>
    </input>
  </fieldset>
  <row>
    <panel>
      <title>Blocked Alerts Count</title>
      <chart>
        <search>
          <query>`meraki_index` sourcetype="meraki:organizationsecurity" $orgid$
| stats count as Count by blocked
| rename blocked as "Blocked"</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
        </search>
        <option name="charting.chart">pie</option>
        <option name="charting.drilldown">none</option>
      </chart>
    </panel>
  </row>
  <row>
    <panel>
      <title>Details of Alerts</title>
      <table>
        <search>
          <query>`meraki_index` sourcetype="meraki:organizationsecurity" $orgid$
| rename eventType as "Event Type", deviceMac as "Device Mac", signature as "Signature", priority as "Priority", protocol as "Protocol"
| table "Event Type", "Device Mac", "Signature", "Priority",  "Protocol"</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
        </search>
        <option name="drilldown">none</option>
      </table>
    </panel>
  </row>
  <row>
    <panel>
      <title>Alerts Over Time</title>
      <chart>
        <search>
          <query>`meraki_index` sourcetype="meraki:organizationsecurity" $orgid$
| timechart count as "Alert Count" span=1d</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
        </search>
        <option name="charting.chart">line</option>
        <option name="charting.drilldown">none</option>
      </chart>
    </panel>
  </row>
</form>