<form version="1.1">
  <label>Appliance VPN Statuses</label>
  <fieldset submitButton="false">
    <input type="time" token="time">
      <label>Time</label>
      <default>
        <earliest>-24h@h</earliest>
        <latest>now</latest>
      </default>
    </input>
    <input type="dropdown" token="orgid">
      <label>Organization Id</label>
      <choice value="*">All</choice>
      <default>*</default>
      <prefix>organizationId = "</prefix>
      <suffix>"</suffix>
      <fieldForLabel>name</fieldForLabel>
      <fieldForValue>id</fieldForValue>
      <search>
        <query>`meraki_index` sourcetype="meraki:organizations"
| dedup id
| table id, name</query>
        <earliest>$time.earliest$</earliest>
        <latest>$time.latest$</latest>
      </search>
    </input>
  </fieldset>
  <row>
    <panel>
      <title>VPN Status Data</title>
      <table>
        <search>
          <query>`meraki_index` sourcetype="meraki:appliancesdwanstatuses" $orgid$ 
| rename networkName as "Network Name", deviceStatus as "Device Status", Subnet_Name as "Subnet Name", uplinks{}.interface as Interface, exportedSubnets{}.subnet as Subnet 
| table "Network Name","Device Status", "Interface", "Subnet Name", "Subnet"</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
        </search>
        <option name="drilldown">none</option>
        <option name="refresh.display">progressbar</option>
      </table>
    </panel>
  </row>
</form>