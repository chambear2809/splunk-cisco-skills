<form version="1.1">
  <label>Air Marshal</label>
  <fieldset submitButton="false">
    <input type="time" token="time">
      <label>Time</label>
      <default>
        <earliest>-24h@h</earliest>
        <latest>now</latest>
      </default>
    </input>
    <input type="dropdown" token="orgid">
      <label>Organization Id</label>
      <choice value="*">All</choice>
      <default>*</default>
      <prefix>organizationId = "</prefix>
      <suffix>"</suffix>
      <fieldForLabel>name</fieldForLabel>
      <fieldForValue>id</fieldForValue>
      <search>
        <query>`meraki_index` sourcetype="meraki:organizations"
| dedup id
| table id, name</query>
        <earliest>$time.earliest$</earliest>
        <latest>$time.latest$</latest>
      </search>
    </input>
  </fieldset>
  <row>
    <panel>
      <title>Airmarshal Rogue AP Data</title>
      <table>
        <search>
          <query>`meraki_index` sourcetype="meraki:airmarshal" $orgid$
| rename ssid as "SSID", channels{} as "Channels" 
| table "SSID", "Channels"</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
        </search>
        <option name="drilldown">none</option>
      </table>
    </panel>
  </row>
  <row>
    <panel>
      <title>Top SSIDs by Detection Count</title>
      <table>
        <search>
          <query>`meraki_index` sourcetype="meraki:airmarshal" $orgid$
| rename "ssid" as "SSID"
| stats count as "Count" by "SSID"
| sort - 0 Count</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
        </search>
        <option name="drilldown">row</option>
        <drilldown>
          <link target="_blank">search?q=`meraki_index` sourcetype="meraki:airmarshal" $orgid$ ssid="$row.SSID$"&amp;earliest=$time.earliest$&amp;latest=$time.latest$</link>
        </drilldown>
      </table>
    </panel>
    <panel>
      <title>Top Channels by Detection</title>
      <table>
        <search>
          <query>`meraki_index` sourcetype="meraki:airmarshal" $orgid$
| mvexpand channels{}
| stats count as "Count" by channels{}
| rename channels{} as "Channel"
| sort - 0 Count</query>
          <earliest>$time.earliest$</earliest>
          <latest>$time.latest$</latest>
        </search>
        <option name="drilldown">none</option>
      </table>
    </panel>
  </row>
</form>