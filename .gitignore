# --- Secrets ---
credentials

# --- TA package binaries (install from Splunkbase or keep in LFS) ---
splunk-ta/*.tgz
splunk-ta/*.spl
splunk-ta/*.tar.gz
splunk-ta/*.rpm
splunk-ta/*.deb
splunk-ta/*.msi
splunk-ta/*.dmg
splunk-ta/*.pkg
splunk-ta/*.txz
splunk-ta/*.p5p
splunk-ta/*.Z
splunk-ta/.latest-splunk-enterprise-*.json
splunk-ta/.latest-splunk-universal-forwarder-*.json

# --- Also ignore the splunk_ta directory ---
splunk_ta/

# --- Unpacked vendor packages (review-only, too large for git) ---
splunk-ta/_unpacked/

# --- Python cache ---
**/__pycache__/
**/*.pyc
.pytest_cache/
.ruff_cache/

# --- Local virtualenvs ---
.venv/
venv/

# --- macOS ---
.DS_Store

# --- Root-level SKILL.md (ACS staging context, local only) ---
# Per-skill SKILL.md files under skills/ are tracked normally.
/SKILL.md

# --- IDE / agent scaffolding (not project content) ---
skills-cursor/
plugins/
/commands/
subagents/
projects/tmp-*
.claude/settings.local.json

# --- Local TA intake templates ---
**/template.local

# --- Local ITSI config workflow reports ---
/skills/splunk-itsi-config/reports/

