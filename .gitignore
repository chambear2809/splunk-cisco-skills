# --- Secrets ---
credentials

# --- TA package binaries (install from Splunkbase or keep in LFS) ---
splunk-ta/*.tgz
splunk-ta/*.spl
splunk-ta/*.tar.gz
splunk-ta/*.rpm
splunk-ta/*.deb
splunk-ta/.latest-splunk-enterprise-*.json

# --- Also ignore the splunk_ta directory ---
splunk_ta/

# --- Unpacked vendor packages (review-only, too large for git) ---
splunk-ta/_unpacked/

# --- Python cache ---
**/__pycache__/
**/*.pyc
.pytest_cache/
.ruff_cache/

# --- Local virtualenvs ---
.venv/
venv/

# --- macOS ---
.DS_Store

# --- Root-level SKILL.md (ACS staging context, local only) ---
# Per-skill SKILL.md files under skills/ are tracked normally.
/SKILL.md

# --- IDE / agent scaffolding (not project content) ---
skills-cursor/
plugins/
/commands/
subagents/
projects/tmp-*
.claude/settings.local.json

# --- Local TA intake templates ---
**/template.local

# --- Local ITSI config workflow reports ---
/skills/splunk-itsi-config/reports/

# --- Local rendered deployment assets ---
/sc4s-rendered/
/sc4snmp-rendered/
/splunk-agent-management-rendered/
/splunk-workload-management-rendered/
/splunk-hec-service-rendered/
/splunk-federated-search-rendered/
/splunk-smartstore-rendered/
/splunk-monitoring-console-rendered/
/splunk-enterprise-k8s-rendered/
/splunk-observability-otel-rendered/
/splunk-observability-dashboard-rendered/
/ta-for-indexers-rendered/
/splunk-mcp-rendered/*
!/splunk-mcp-rendered/run-splunk-mcp.js
error.log
