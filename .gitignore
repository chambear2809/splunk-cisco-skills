# --- Secrets ---
credentials

# --- TA package binaries (install from Splunkbase or keep in LFS) ---
splunk-ta/*.tgz
splunk-ta/*.spl
splunk-ta/*.tar.gz
splunk-ta/*.rpm
splunk-ta/*.deb
splunk-ta/.latest-splunk-enterprise-*.json

# --- Also ignore the splunk_ta directory ---
splunk_ta/

# --- Unpacked vendor packages (review-only, too large for git) ---
splunk-ta/_unpacked/

# --- Python cache ---
**/__pycache__/
**/*.pyc

# --- macOS ---
.DS_Store

# --- Root-level SKILL.md (ACS staging context, local only) ---
# Per-skill SKILL.md files under skills/ are tracked normally.
/SKILL.md

# --- IDE / agent scaffolding (not project content) ---
skills-cursor/
plugins/
commands/
subagents/
projects/tmp-*

# --- Local TA intake templates ---
**/template.local

# --- Local SC4S rendered deployment assets ---
/sc4s-rendered/
/sc4snmp-rendered/
/splunk-mcp-rendered/
error.log
